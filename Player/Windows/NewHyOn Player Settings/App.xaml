<Application x:Class="NewHyOn.Player.Settings.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <Style x:Key="FlatButtonBase" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D7DEE5" />
            <Setter Property="Foreground" Value="#20303F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogPrimaryButton" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Width" Value="96" />
            <Setter Property="Background" Value="#177E89" />
            <Setter Property="BorderBrush" Value="#177E89" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style x:Key="DialogSecondaryButton" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Width" Value="132" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D7DEE5" />
            <Setter Property="Foreground" Value="#20303F" />
        </Style>

        <Style x:Key="TrafficLightButtonBase" TargetType="Button">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Background" Value="#D1D5DB" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
        </Style>

        <Style x:Key="TrafficCloseButton" TargetType="Button" BasedOn="{StaticResource TrafficLightButtonBase}">
            <Setter Property="Background" Value="#FF5F57" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <Grid>
                                <Ellipse Margin="1"
                                         Fill="{TemplateBinding Background}" />
                                <Grid x:Name="IconLayer"
                                      Width="8"
                                      Height="8"
                                      Opacity="0">
                                    <Rectangle Width="8"
                                               Height="1.2"
                                               RadiusX="0.6"
                                               RadiusY="0.6"
                                               Fill="#5E5E5E"
                                               RenderTransformOrigin="0.5,0.5">
                                        <Rectangle.RenderTransform>
                                            <RotateTransform Angle="45" />
                                        </Rectangle.RenderTransform>
                                    </Rectangle>
                                    <Rectangle Width="8"
                                               Height="1.2"
                                               RadiusX="0.6"
                                               RadiusY="0.6"
                                               Fill="#5E5E5E"
                                               RenderTransformOrigin="0.5,0.5">
                                        <Rectangle.RenderTransform>
                                            <RotateTransform Angle="-45" />
                                        </Rectangle.RenderTransform>
                                    </Rectangle>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                                <Setter TargetName="IconLayer" Property="Opacity" Value="1" />
                            </DataTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.76" />
                                <Setter TargetName="IconLayer" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrafficMinimizeButton" TargetType="Button" BasedOn="{StaticResource TrafficLightButtonBase}">
            <Setter Property="Background" Value="#FEBC2E" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <Grid>
                                <Ellipse Margin="1"
                                         Fill="{TemplateBinding Background}" />
                                <Rectangle x:Name="IconLayer"
                                           Width="8"
                                           Height="1.2"
                                           RadiusX="0.6"
                                           RadiusY="0.6"
                                           Fill="#5E5E5E"
                                           Opacity="0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                                <Setter TargetName="IconLayer" Property="Opacity" Value="1" />
                            </DataTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.76" />
                                <Setter TargetName="IconLayer" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#EEF3F8" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D9E2EC" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#64748B" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#166534" />
    </Application.Resources>
</Application>
