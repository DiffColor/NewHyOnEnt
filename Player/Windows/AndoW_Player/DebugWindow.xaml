<Window x:Class="HyOnPlayer.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debug Info"
        Width="520"
        Height="720"
        Background="Black"
        Foreground="White"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Topmost="True"
        ShowInTaskbar="True">
    <Grid Margin="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="디버그 정보" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

                <TextBlock Text="현재 재생" FontWeight="Bold"/>
                <TextBlock x:Name="PlaybackText" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <TextBlock Text="컨텐츠" FontWeight="Bold"/>
                <TextBlock x:Name="ContentText" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <TextBlock Text="다음 구성" FontWeight="Bold"/>
                <TextBlock x:Name="NextText" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <TextBlock Text="커맨드/업데이트" FontWeight="Bold"/>
                <TextBlock x:Name="CommandText" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <TextBlock Text="업데이트 큐" FontWeight="Bold"/>
                <ListBox x:Name="QueueList" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4,0,4">
                                <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
