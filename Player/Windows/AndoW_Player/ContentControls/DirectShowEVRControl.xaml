<UserControl x:Class="HyOnPlayer.DirectShowEVRControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
             SizeChanged="DirectShowEVRControl_SizeChanged"
             Loaded="DirectShowEVRControl_Loaded"
             Unloaded="DirectShowEVRControl_Unloaded" >
    <Grid x:Name="RootGrid" Background="Black">
        <WindowsFormsHost>
            <wf:Panel x:Name="EVRdocker" BackColor="Black"/>
        </WindowsFormsHost>
    </Grid>
</UserControl>
