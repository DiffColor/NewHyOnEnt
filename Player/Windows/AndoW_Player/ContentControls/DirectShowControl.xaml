<UserControl x:Class="HyOnPlayer.DirectShowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
             SizeChanged="DirectShowControl_SizeChanged"
             Loaded="DirectShowControl_Loaded"
             Unloaded="DirectShowControl_Unloaded">
    <Grid x:Name="RootGrid" Background="Black">
        <WindowsFormsHost>
            <wf:Panel x:Name="DSdocker" BackColor="Black"/>
        </WindowsFormsHost>
    </Grid>
</UserControl>
