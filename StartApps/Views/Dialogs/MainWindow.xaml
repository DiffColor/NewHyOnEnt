<ui:FluentWindow
    x:Class="StartApps.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:StartApps.Converters"
    xmlns:viewModels="clr-namespace:StartApps.ViewModels"
    mc:Ignorable="d"
    WindowStartupLocation="CenterScreen"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True"
    WindowCornerPreference="Round"
    BorderThickness="0"
    ResizeMode="CanResize"
    Width="1200" Height="720" MinWidth="740"
    Icon="pack://application:,,,/StartApps;component/Assets/startapps.ico" Background="Transparent"
    Loaded="FluentWindow_OnLoaded"
    Closing="FluentWindow_OnClosing"
    d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel}">

    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#20263A" />
        <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="#F5F7FF" />
        <SolidColorBrush x:Key="ActiveAppForegroundBrush" Color="#B9C8FF" />
        <SolidColorBrush x:Key="ParallelSectionBackgroundBrush" Color="#1E2537" />
        <SolidColorBrush x:Key="SequentialSectionBackgroundBrush" Color="#231E34" />
        <SolidColorBrush x:Key="ParallelSectionBorderBrush" Color="#4B617F" />
        <SolidColorBrush x:Key="SequentialSectionBorderBrush" Color="#6A4C89" />
        <SolidColorBrush x:Key="ParallelHeaderBrush" Color="#F4DDB2" />
        <SolidColorBrush x:Key="SequentialHeaderBrush" Color="#C4E3FF" />
        <SolidColorBrush x:Key="ParallelPlaceholderBrush" Color="#B39A7A" />
        <SolidColorBrush x:Key="SequentialPlaceholderBrush" Color="#90A6CD" />

        <Style x:Key="ActiveWindowBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}}"
                             Value="True">
                    <Setter Property="BorderBrush" Value="#905D5D" />
                    <!-- Rose Taupe -->
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <converters:BoolToTextConverter x:Key="BoolToTextConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:IndexToOrderConverter x:Key="IndexToOrderConverter" />

        <LinearGradientBrush x:Key="AppCardGradientDefault" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF2D2E37" Offset="0"/>
            <GradientStop Color="#FF1F2027" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AppCardGradientRdb" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF3B8DFF" Offset="0"/>
            <GradientStop Color="#FF214EAA" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AppCardGradientFtp" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF4DD0E1" Offset="0"/>
            <GradientStop Color="#FF00796B" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AppCardGradientMsg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF4CAF50" Offset="0"/>
            <GradientStop Color="#FF1B5E20" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AppCardGradientApp" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFAA5CDB" Offset="0"/>
            <GradientStop Color="#FF6A1B9A" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="CardDisabledBrush" Color="#FFB7C2CC" />
        <DataTemplate x:Key="AppCardTemplate" DataType="{x:Type viewModels:AppEntryViewModel}">
            <Border Padding="10" CornerRadius="18" Height="110" Width="220"
                    PreviewMouseLeftButtonDown="AppCard_PreviewMouseLeftButtonDown"
                    PreviewMouseMove="AppCard_PreviewMouseMove"
                    MouseLeftButtonUp="AppCard_MouseLeftButtonUp">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="#33000000" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Background" Value="{StaticResource AppCardGradientDefault}" />
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.35" Color="#80000000"/>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Definition.Type}" Value="Rdb">
                                <Setter Property="Background" Value="{StaticResource AppCardGradientRdb}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Definition.Type}" Value="Ftp">
                                <Setter Property="Background" Value="{StaticResource AppCardGradientFtp}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Definition.Type}" Value="Msg">
                                <Setter Property="Background" Value="{StaticResource AppCardGradientMsg}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Definition.Type}" Value="Msg472">
                                <Setter Property="Background" Value="{StaticResource AppCardGradientMsg}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Definition.Type}" Value="Msg10">
                                <Setter Property="Background" Value="{StaticResource AppCardGradientMsg}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Definition.Type}" Value="App">
                                <Setter Property="Background" Value="{StaticResource AppCardGradientApp}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                <Setter Property="Background" Value="{StaticResource CardDisabledBrush}" />
                                <Setter Property="BorderBrush" Value="#88FFFFFF" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                <Setter Property="BorderBrush" Value="#66FFFFFF" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.015" ScaleY="1.015"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="설정" Tag="{Binding}" Click="AppCard_SettingsClick" />
                        <Separator />
                        <MenuItem Header="삭제" Tag="{Binding}" Click="AppCard_DeleteClick" />
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                   
                    <Border Grid.Row="0" Width="28" Height="28" CornerRadius="14" Background="#33FFFFFF"
                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,2,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Zone}" Value="Sequential">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource IndexToOrderConverter}}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#F0FFFFFF" />
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#33000000" Padding="6,3" CornerRadius="10" Margin="0,0,0,0">
                            <TextBlock Text="{Binding TypeLabel}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <!--<Border Background="#55FFFFFF" Padding="6,3" CornerRadius="10" Margin="0,0,8,0">
                            <TextBlock Text="{Binding Definition.Zone}" FontSize="12" Foreground="#CC000000"/>
                        </Border>
                        <Border Background="#33000000" Padding="6,3" CornerRadius="10">
                            <TextBlock Text="{Binding IsEnabled, Converter={StaticResource BoolToTextConverter}, ConverterParameter='활성|비활성'}"
                                       FontSize="12" Foreground="White"/>
                        </Border>-->
                    </StackPanel>

                    <TextBlock Margin="6,6,0,0" Width="190" MaxWidth="190" Grid.Row="1" Text="{Binding DisplayName}" FontSize="18" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Left" />

                    <Grid Grid.Row="2" Margin="6,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="12" Height="12" VerticalAlignment="Center" Fill="#66FFFFFF">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#66FFFFFF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Fill" Value="#5CFF72"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                            <Setter Property="Fill" Value="#FFB0BEC5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Grid.Column="1" MaxWidth="150" TextTrimming="CharacterEllipsis" Text="{Binding StatusDisplay}" Foreground="{Binding StatusColor}" Margin="6,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <ui:ProgressRing Grid.Column="2" Width="20" Height="20" Margin="12,0,0,0"
                                         IsIndeterminate="True"
                                         Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Border 
        Style="{StaticResource ActiveWindowBorderStyle}"
        Background="#202020"
        Margin="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ui:TitleBar
                Grid.Row="0"
                x:Name="AppTitleBar" Title="{Binding AppTitle}" Foreground="{StaticResource TitleBarForegroundBrush}"
                Background="{StaticResource TitleBarBackgroundBrush}" FontSize="18" Padding="14,4,16,0" 
                ShowMaximize="True" ShowMinimize="True" ShowClose="True">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Margin="0,0,-10,0" Source="pack://application:,,,/StartApps;component/Assets/startapps.ico" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>

            <Grid x:Name="DragScopeHost" Grid.Row="1" Grid.RowSpan="2" AllowDrop="True" Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="24,12,20,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ActiveAppCount, StringFormat='현재 활성 앱 : {0}'}"
                               VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource ActiveAppForegroundBrush}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                            <Button Content="RDB" Padding="18,6" Margin="0,0,12,0" Tag="Rdb"
                                    Click="TypeButton_Click"
                                    PreviewMouseLeftButtonDown="TypeButton_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="TypeButton_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="TypeButton_PreviewMouseLeftButtonUp" />
                            <Button Content="FTP" Padding="18,6" Margin="0,0,12,0" Tag="Ftp"
                                    IsEnabled="{Binding CanAddFtp}"
                                    Click="TypeButton_Click"
                                    PreviewMouseLeftButtonDown="TypeButton_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="TypeButton_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="TypeButton_PreviewMouseLeftButtonUp" />
                            <Button Content="MSG472" Padding="18,6" Margin="0,0,12,0" Tag="Msg472"
                                    Click="TypeButton_Click"
                                    PreviewMouseLeftButtonDown="TypeButton_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="TypeButton_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="TypeButton_PreviewMouseLeftButtonUp" />
                            <Button Content="MSG10" Padding="18,6" Margin="0,0,12,0" Tag="Msg10"
                                    Click="TypeButton_Click"
                                    PreviewMouseLeftButtonDown="TypeButton_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="TypeButton_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="TypeButton_PreviewMouseLeftButtonUp" />
                            <Button Content="APP" Padding="18,6" Tag="App"
                                    Click="TypeButton_Click"
                                    PreviewMouseLeftButtonDown="TypeButton_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="TypeButton_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="TypeButton_PreviewMouseLeftButtonUp" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="20,4,20,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource ParallelSectionBackgroundBrush}" CornerRadius="6"
                            BorderBrush="{StaticResource ParallelSectionBorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,6,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="즉시 실행 영역" FontSize="20" FontWeight="SemiBold"
                                           Foreground="{StaticResource ParallelHeaderBrush}"/>
                                    <Border Background="{DynamicResource UiBrushAccent}" Padding="8,2" CornerRadius="12" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding ParallelApps.Count, StringFormat='총 {0}개'}" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding NextParallelCheckDisplay}" Margin="12,2,0,0"
                                           VerticalAlignment="Center" Foreground="{StaticResource ParallelPlaceholderBrush}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,12,0,0" >
                                <TextBlock Text="아래에 앱 버튼을 드래그하여 배치하세요."
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource ParallelPlaceholderBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ParallelApps.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl x:Name="ParallelList"
                                              ItemsSource="{Binding ParallelApps}"
                                              ItemTemplate="{StaticResource AppCardTemplate}"
                                              AllowDrop="True"
                                              DragEnter="AppList_DragEnter"
                                              DragOver="AppList_DragOver"
                                              DragLeave="AppList_DragLeave"
                                              Drop="AppList_Drop"
                                              Tag="Parallel">
                                    <ItemsControl.Template>
                                        <ControlTemplate TargetType="ItemsControl">
                                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                          VerticalScrollBarVisibility="Auto">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </ControlTemplate>
                                    </ItemsControl.Template>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" ItemWidth="240" ItemHeight="130" Margin="12,0" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource SequentialSectionBackgroundBrush}" CornerRadius="6"
                            BorderBrush="{StaticResource SequentialSectionBorderBrush}" BorderThickness="1" Padding="12" Margin="6,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="순차 실행 영역" FontSize="20" FontWeight="SemiBold"
                                           Foreground="{StaticResource SequentialHeaderBrush}"/>
                                    <Border Background="{DynamicResource UiBrushAccent}" Padding="8,2" CornerRadius="12" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding SequentialApps.Count, StringFormat='총 {0}개'}" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding NextSequentialCheckDisplay}" Margin="12,2,0,0"
                                           VerticalAlignment="Center" Foreground="{StaticResource SequentialPlaceholderBrush}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <TextBlock Text="순차적으로 실행할 앱을 위에서 아래로 정렬하세요."
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource SequentialPlaceholderBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SequentialApps.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl x:Name="SequentialList"
                                              ItemsSource="{Binding SequentialApps}"
                                              ItemTemplate="{StaticResource AppCardTemplate}"
                                              AllowDrop="True"
                                              DragEnter="AppList_DragEnter"
                                              DragOver="AppList_DragOver"
                                              DragLeave="AppList_DragLeave"
                                              Drop="AppList_Drop"
                                              Tag="Sequential"
                                              AlternationCount="1000">
                                    <ItemsControl.Template>
                                        <ControlTemplate TargetType="ItemsControl">
                                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                          VerticalScrollBarVisibility="Auto">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </ControlTemplate>
                                    </ItemsControl.Template>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" ItemWidth="240" ItemHeight="130" Margin="12,0" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</ui:FluentWindow>
