<UserControl x:Class="AndoW_Manager.UserControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="409" Height="26">
    <Grid x:Name="rootGrid">
        <Grid x:Name="LayoutGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="24.5"/>
            </Grid.ColumnDefinitions>
            <Rectangle RadiusX="3" RadiusY="3" Fill="#AD080808" Grid.ColumnSpan="6" Margin="0,0,0,2"/>
            <TextBlock x:Name="TextBlockOrderingNumber" TextWrapping="Wrap" Text="01" FontFamily="Malgun Gothic" Foreground="#FFC2C2C2" HorizontalAlignment="Center" Margin="0,3.208,0,5.208" d:LayoutOverrides="Height"/>
            <TextBlock x:Name="ExitTextBlock" TextWrapping="Wrap" Text="X" FontFamily="Malgun Gothic" FontSize="13.333" Foreground="Gray" Grid.Column="2" d:LayoutOverrides="Width, Height, GridBox" FontWeight="Bold" Margin="6.158,1.398,8.158,5.398"/>
            <Grid Grid.Column="1" Margin="0,0,0,2">
            	<Grid.ColumnDefinitions>
            		<ColumnDefinition Width="39*"/>
            		<ColumnDefinition Width="109*"/>
            		<ColumnDefinition Width="54*"/>
            		<ColumnDefinition Width="38*"/>
            		<ColumnDefinition Width="54*"/>
            		<ColumnDefinition Width="64*"/>
            	</Grid.ColumnDefinitions>
            	<Rectangle x:Name="BackRectangle" Fill="#FF212121" Grid.ColumnSpan="6" Margin="0,0,0.001,0"/>
            	<TextBlock x:Name="TextBlockPageName_Copy2" TextWrapping="NoWrap" Text="Input No:" Foreground="#FF7E7E7E" FontFamily="Malgun Gothic" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Column="2"/>
            	<TextBlock x:Name="TextBlockPageName_Copy" TextWrapping="NoWrap" Text="05" Foreground="#FFB7BD39" FontFamily="Malgun Gothic" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="3"/>
            	<TextBlock x:Name="TextBlockPageName_Copy1" TextWrapping="NoWrap" Text="Name:" Foreground="#FF7E7E7E" FontFamily="Malgun Gothic" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            	<TextBlock x:Name="TextBlockPageName_Copy3" TextWrapping="NoWrap" Text="PC - 01" Foreground="#FF64A859" FontFamily="Malgun Gothic" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Column="1" Margin="5,0,0,0"/>
            	<TextBlock x:Name="TextBlockPageName_Copy4" TextWrapping="NoWrap" Text="Type :" Foreground="#FF7E7E7E" FontFamily="Malgun Gothic" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Column="4"/>
            	<TextBlock x:Name="TextBlockPageName_Copy5" TextWrapping="NoWrap" Text="DVI" Foreground="#FF39BDB1" FontFamily="Malgun Gothic" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="5"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
