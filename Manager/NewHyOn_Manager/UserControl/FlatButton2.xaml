<UserControl x:Class="AndoW_Manager.FlatButton2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="200">
    <Grid x:Name="rootGrid">
        <Grid x:Name="LayoutGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="24.5"/>
            </Grid.ColumnDefinitions>
            <Rectangle RadiusX="3" RadiusY="3" Fill="#AD080808" Grid.ColumnSpan="6" Margin="0"/>
            <TextBlock x:Name="TextBlockOrderingNumber" TextWrapping="Wrap" Text="01" FontFamily="Malgun Gothic" Foreground="#FFC2C2C2" HorizontalAlignment="Center" Margin="0,3.208,0,5.208" d:LayoutOverrides="Height"/>
            <TextBlock x:Name="BtnDisplayNameTextBlk" TextWrapping="Wrap" Text="Page Maker" FontFamily="Malgun Gothic" FontSize="24" Foreground="Gray" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="ExitTextBlock" TextWrapping="Wrap" Text="X" FontFamily="Malgun Gothic" FontSize="13.333" Foreground="Gray" Grid.Column="2" d:LayoutOverrides="Width, Height, GridBox" FontWeight="Bold" Margin="6.158,1.398,8.158,5.398"/>
        </Grid>
    </Grid>
</UserControl>
