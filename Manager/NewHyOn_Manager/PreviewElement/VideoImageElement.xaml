             d:DesignHeight="300" d:DesignWidth="300">
    <Grid x:Name="rootGrid" OpacityMask="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.739*"/>
        </Grid.RowDefinitions>
        <Grid x:Name="MoveAndResizeGrid" Margin="0,-15" Visibility="Hidden">
        	<Grid.ColumnDefinitions>
        		<ColumnDefinition/>
        		<ColumnDefinition Width="15"/>
        	</Grid.ColumnDefinitions>
        	<Grid.RowDefinitions>
        		<RowDefinition Height="15"/>
        		<RowDefinition/>
        		<RowDefinition Height="15"/>
        	</Grid.RowDefinitions>
        	<TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="MOVE" Width="40" Foreground="Black"/>
        	<TextBlock HorizontalAlignment="Right" TextWrapping="Wrap" Text="MOVE" Grid.Row="2" Width="40" Foreground="Black"/>
        	<Rectangle x:Name="MoveTopRectangle" Fill="#7F707070" Stroke="#7F000000" Cursor="Hand"/>
        	<Rectangle x:Name="MoveBottomRectangle" Fill="#7F707070" Stroke="#7F000000" Grid.Row="2" Cursor="Hand"/>
        	<Rectangle x:Name="ResizeRectangle" Stroke="Black" Grid.Row="2" Grid.Column="1" StrokeThickness="0" Cursor="SizeNWSE" Fill="{DynamicResource scale}"/>
        	<Rectangle x:Name="ExitRectangle" Grid.Column="1" Fill="White" Stroke="Black" StrokeThickness="0" HorizontalAlignment="Right" Width="15"/>
        	<Path x:Name="exitPath1" Grid.Column="1" Data="M300,0 L285,15" Fill="#FFAB6529" Stretch="Fill" Stroke="Red" HorizontalAlignment="Right" Width="15" StrokeThickness="2"/>
        	<Path x:Name="exitPath2" Grid.Column="1" Data="M285,0 L300,15" Fill="#FF3F3FE2" Stretch="Fill" Stroke="Red" HorizontalAlignment="Right" Width="15" StrokeThickness="2"/>
        </Grid>
        
