<UserControl x:Class="AndoW_Manager.ScrollTextElement4"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="300">
    <Grid x:Name="rootGrid">
        <Grid x:Name="MoveAndResizeGrid" Margin="0,-15" Visibility="Hidden">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="15"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="15"/>
                <RowDefinition/>
                <RowDefinition Height="15"/>
            </Grid.RowDefinitions>
            <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="MOVE" Width="40"/>
            <TextBlock HorizontalAlignment="Right" TextWrapping="Wrap" Text="MOVE" Grid.Row="2" Width="40"/>
            <Rectangle x:Name="MoveTopRectangle" Grid.ColumnSpan="2" Fill="#7F707070" Stroke="#4C000000" Cursor="Hand"/>
            <Rectangle x:Name="MoveBottomRectangle" Fill="#7F707070" Stroke="#4C000000" Grid.Row="2" Cursor="Hand"/>
            <Rectangle x:Name="ResizeRectangle" Stroke="Black" Grid.Row="2" Grid.Column="1" StrokeThickness="0" Cursor="SizeNWSE" Fill="{DynamicResource scale}"/>
            <Rectangle x:Name="ExitRectangle" Grid.Column="1" Fill="White" Stroke="Black" StrokeThickness="0" HorizontalAlignment="Right" Width="15"/>
            <Path x:Name="exitPath1" Grid.Column="1" Data="M300,0 L285,15" Fill="Red" Stretch="Fill" Stroke="Red" HorizontalAlignment="Right" Width="15" StrokeThickness="2"/>
            <Path x:Name="exitPath2" Grid.Column="1" Data="M285,0 L300,15" Fill="Red" Stretch="Fill" Stroke="Red" HorizontalAlignment="Right" Width="15" StrokeThickness="2"/>
        </Grid>
        <Grid x:Name="ContentGrid" Background="Black">
            <!--<Grid.ContextMenu>
                <ContextMenu Name="MenuOnCanvas">
                    	<MenuItem Header="Bring to Front" ToolTip="Bring the selected object to Front."  x:Name="MenuBringToFront"/>
                        <MenuItem Header="Bring to Back" ToolTip="Bring the selected object to Back."  x:Name="MenuBringToBack"/>
					    <MenuItem Header="Bring to Front One Step" ToolTip="Bring the selected object to Front One Step."  x:Name="MenuBringToFrontOneStep"/>
					    <MenuItem Header="Bring to Back One Step" ToolTip="Bring the selected object to Back One Step."  x:Name="MenuBringToBackOneStep"/>
                        <MenuItem Header="Element Copy" ToolTip="Copy Element."  x:Name="ElementCopy"/>
				</ContextMenu>
            </Grid.ContextMenu>-->
            <Canvas  ClipToBounds="True" x:Name="canMain" >
                <TextBlock  x:Name="tbmarquee" Text="This text is Scroll" FontFamily="Gaeul" FontSize="29.333" Foreground="White"/>
                <!--<Button Name="tbmarquee"></Button>-->
            </Canvas>
        </Grid>
    </Grid>
</UserControl>
