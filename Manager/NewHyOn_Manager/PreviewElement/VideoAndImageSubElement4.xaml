<UserControl x:Class="HyonManager.VideoAndImageSubElement4"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <Grid x:Name="ContentGrid">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.776,0.917" StartPoint="0.224,0.083">
                    <GradientStop Color="Black" Offset="0.519"/>
                    <GradientStop Color="#FF1D1D1D"/>
                    <GradientStop Color="#FF0C0C0C" Offset="0.491"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.ContextMenu>
                <ContextMenu x:Name="MenuOnCanvas">
                    <MenuItem Header="Bring to Front" ToolTip="Bring the selected object to Front."  x:Name="MenuBringToFront"/>
                    <MenuItem Header="Bring to Back" ToolTip="Bring the selected object to Back."  x:Name="MenuBringToBack"/>
                    <MenuItem Header="Bring to Front One Step" ToolTip="Bring the selected object to Front One Step."  x:Name="MenuBringToFrontOneStep"/>
                    <MenuItem Header="Bring to Back One Step" ToolTip="Bring the selected object to Back One Step."  x:Name="MenuBringToBackOneStep"/>
                    <MenuItem Header="Element Copy" ToolTip="Copy Element."  x:Name="ElementCopy"/>
                </ContextMenu>
            </Grid.ContextMenu>
            <MediaElement x:Name="MediaElementOnMultimedia" Stretch="Fill" OpacityMask="Black"/>
        </Grid>
        <WebBrowser x:Name="WebBrowser1"/>
    </Grid>
</UserControl>
