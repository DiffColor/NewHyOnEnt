<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:tools="clr-namespace:TurtleTools"
    mc:Ignorable="d" x:Class="AndoW_Manager.BatchUpgradeWindow" 
    IsVisibleChanged="Window_IsVisibleChanged" AllowsTransparency="True"
    Title="알림창" Height="800" Width="1180" WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style x:Key="Btn_default2" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition From="Pressed" GeneratedDuration="0:0:0.3"/>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF08193B"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF00071A"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[2].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF051A45"/>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[2].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF000E1B"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF000914"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF000D35"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Stroke).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#68000000"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Stroke).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#19000000"/>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Rectangle x:Name="rectangle" RadiusY="4" RadiusX="4">
                                <Rectangle.Fill>
                                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                        <GradientStop Color="#FF0C0C0C" Offset="0.667"/>
                                        <GradientStop Color="#FF252525"/>
                                        <GradientStop Color="#FF121212" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.Stroke>
                                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                        <GradientStop Color="#59000000" Offset="0"/>
                                        <GradientStop Color="#19FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Stroke>
                            </Rectangle>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True"/>
                            <Trigger Property="IsDefaulted" Value="True"/>
                            <Trigger Property="IsMouseOver" Value="True"/>
                            <Trigger Property="IsPressed" Value="True"/>
                            <Trigger Property="IsEnabled" Value="False"/>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnWin_1" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition GeneratedDuration="0" To="MouseOver">
                                            <VisualTransition.GeneratedEasingFunction>
                                                <BackEase EasingMode="EaseOut"/>
                                            </VisualTransition.GeneratedEasingFunction>
                                        </VisualTransition>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="rectangle">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed"/>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Rectangle x:Name="rectangle" Fill="#59000000" RadiusY="3" RadiusX="3" Stroke="#660F313F" Opacity="0"/>
                            <ContentPresenter OpacityMask="Black"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True"/>
                            <Trigger Property="IsDefaulted" Value="True"/>
                            <Trigger Property="IsMouseOver" Value="True"/>
                            <Trigger Property="IsPressed" Value="True"/>
                            <Trigger Property="IsEnabled" Value="False"/>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Btn_defaultSW_Local" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition From="Pressed" GeneratedDuration="0:0:0.3"/>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF08193B"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF00071A"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[2].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF051A45"/>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[2].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF000E1B"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF000914"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF000D35"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Stroke).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#68000000"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Stroke).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#19000000"/>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Rectangle x:Name="rectangle" RadiusY="0" RadiusX="0">
                                <Rectangle.Fill>
                                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                        <GradientStop Color="#FF0C0C0C" Offset="0.667"/>
                                        <GradientStop Color="#FF252525"/>
                                        <GradientStop Color="#FF121212" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.Stroke>
                                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                        <GradientStop Color="#59000000" Offset="0"/>
                                        <GradientStop Color="#19FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Stroke>
                            </Rectangle>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True"/>
                            <Trigger Property="IsDefaulted" Value="True"/>
                            <Trigger Property="IsMouseOver" Value="True"/>
                            <Trigger Property="IsPressed" Value="True"/>
                            <Trigger Property="IsEnabled" Value="False"/>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#FFE4E8F1">
        <Grid.RowDefinitions>
            <RowDefinition Height="242*"/>
        </Grid.RowDefinitions>
        <Rectangle Fill="#3302133A" Margin="10,10,-5,-5">
            <Rectangle.Effect>
                <BlurEffect Radius="50"/>
            </Rectangle.Effect>
        </Rectangle>

        <Border BorderThickness="2" BorderBrush="#FF4A4A9A" Grid.RowSpan="2" Background="#FFF4F6FB">
            <Grid x:Name="LayoutGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="27"/>
                    <RowDefinition Height="40"/>
                    <!--<RowDefinition Height="35"/>-->
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Rectangle x:Name="titleRect" PreviewMouseLeftButtonDown="BtnWin_drag_PreviewMouseLeftButtonDown" Stroke="#FF1E2128">
                    <Rectangle.Fill>
                        <LinearGradientBrush EndPoint="1.003,0.5" StartPoint="0.001,0.5">
                            <GradientStop Color="Black"/>
                            <GradientStop Color="#FF5252AB" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Grid x:Name="WinTOP" Margin="0,3.5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="109"/>
                    </Grid.ColumnDefinitions>
                </Grid>
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" Margin="7,0,0,0">
                    <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" FontFamily="Malgun Gothic" FontSize="13.333" IsEnabled="False" Text="플레이어 일괄 업그레이드" VerticalAlignment="Center" Padding="0,0,0,3" Margin="0,0,0,1" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Fill="#FFB5B8CE"/>
                    <StackPanel Orientation="Horizontal" Grid.ColumnSpan="3" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                        <TextBlock x:Name="TextAngleGrade5_Copy7" TextWrapping="Wrap" Text="업그레이드 파일 경로 :" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="13.333" Margin="12,0,0,0"/>
                        <tools:TextBoxWithEllipsis x:Name="APKFilePathTBox" VerticalAlignment="Center" IsEllipsisEnabled="True" EllipsisPlacement="Center" VerticalContentAlignment="Center" Height="30" Width="815" HorizontalAlignment="Left" HorizontalContentAlignment="Left" Margin="7,0,0,0" Background="White" />
                        <Button x:Name="SelectFilePath" Click="SelectFilePath_Click" Style="{DynamicResource ButtonStyle3}" Foreground="Black"  Content="파일 선택" Width="90" Height="30" Margin="2,0,0,0" />
                        <Button Visibility="Collapsed" x:Name="BTN0DO_Copy" Style="{DynamicResource Btn_defaultSW}" Height="30" Width="120" Margin="8,2.5,2,2.5">
                            <TextBlock x:Name="TextAngleGrade1" TextWrapping="Wrap" Text="업데이트 중지" Foreground="#FFEC6F40" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="13.333"/>
                        </Button>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="3" Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid x:Name="ContentsListGrid" Margin="10,0,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="42"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Rectangle Fill="#FFD9DFEC" Stroke="White" Grid.Row="1" RadiusX="5" RadiusY="5" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
								VerticalAlignment="Center" Text="플레이어 목록" TextWrapping="Wrap" HorizontalAlignment="Left" FontFamily="Malgun Gothic" FontSize="13.333" Foreground="Black" Margin="12,0,0,0"/>
                        </StackPanel>
                        <ScrollViewer x:Name="ContentsListScrollViewer" Style="{StaticResource ModernScrollViewer}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Auto" Grid.Row="1" Margin="10,10,10,10" BorderThickness="1" BorderBrush="White" Background="#FF252525">
                            <WrapPanel x:Name="PlayerWrapPanel" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" Margin="8"/>
                        </ScrollViewer>
                        <TextBlock x:Name="TextBlockPageName_Copy" TextWrapping="NoWrap" Text="플레이어가 없습니다." Foreground="#FFE6E6E6" FontFamily="Malgun Gothic" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14.667" Grid.RowSpan="2"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">
                            <Button x:Name="BTN0DO_Copy1" Style="{DynamicResource Btn_defaultSW}" Height="30" HorizontalAlignment="Right" Width="80" VerticalAlignment="Center" Margin="0,0,7,0">
                                <TextBlock x:Name="TextAngleGrade2" TextWrapping="Wrap" Text="모두 선택" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic"/>
                            </Button>
                            <Button x:Name="BTN0DO_Copy3" Style="{DynamicResource Btn_defaultSW}" Height="30" HorizontalAlignment="Right" Width="80" VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock x:Name="TextAngleGrade4" TextWrapping="Wrap" Text="모두 해제" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic"/>
                            </Button>
                            <Button x:Name="BTN0DO_Copy2" Style="{DynamicResource ButtonStyle2}" Height="30" Width="110" Margin="11,0,0,0">
                                <TextBlock x:Name="TextAngleGrade3" TextWrapping="Wrap" Text="업그레이드 요청" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontWeight="Bold"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,7,0">
                    <Button x:Name="MaximizeBTN" Height="21" Margin="0,0,5,0" Style="{DynamicResource BtnWin_1}" HorizontalAlignment="Right" Width="28" BorderThickness="1,1,1,2" Foreground="White">
                        <TextBlock
							VerticalAlignment="Center" Text="M" TextWrapping="Wrap" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="14.667" Foreground="#FFCBCBCB"/>
                    </Button>
                    <Button x:Name="BtnWin_close" Height="21" Style="{DynamicResource BtnWin_1}" HorizontalAlignment="Right" Width="28" Click="BtnWin_close_Click" BorderThickness="1,1,1,2" Foreground="White">
                        <Path Data="M8.2080002,0 L11.875,0 11.875,8.2080001 20.083,8.2080001 20.083,11.875 11.875,11.875 11.875,20.083 8.2080002,20.083 8.2080002,11.875 0,11.875 0,8.2080001 8.2080002,8.2080001 z" Fill="White" HorizontalAlignment="Center" RenderTransformOrigin="0.499999995441284,0.500000004558718" Stretch="Fill" StrokeThickness="0" Width="13" Height="13" VerticalAlignment="Center" Margin="0" >
                            <Path.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-135"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Path.RenderTransform>
                        </Path>
                    </Button>
                </StackPanel>
                <!--<StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Grid.Row="2">
					<TextBlock x:Name="TextAngleGrade5_Copy1" TextWrapping="Wrap" Text="업데이트 현황 : " Foreground="#FF48FF72" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="13.333" Margin="12,0,0,0"/>
					<TextBlock x:Name="TextAngleGrade5_Copy" TextWrapping="Wrap" Text="0 / 0" Foreground="#FFE8FF00" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="16" Margin="12,0,0,0" FontWeight="Bold"/>
					<TextBlock x:Name="TextAngleGrade5_Copy2" TextWrapping="Wrap" Text="현재 업데이트 중인 플레이어 : " Foreground="#FFEAEAEA" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="13.333" Margin="65,0,0,0"/>
					<TextBlock x:Name="TextAngleGrade5_Copy3" TextWrapping="Wrap" Text="" Foreground="#FFF5EC26" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="16" Margin="5,0,0,0" FontWeight="Bold"/>
				</StackPanel>-->
                <Grid x:Name="UpdateGrid" Grid.Row="1" Grid.RowSpan="3" Background="#A3686868" Visibility="Hidden">
                    <Button x:Name="BTN0DO_Copy5" Style="{DynamicResource Btn_defaultSW}" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,30,30" Width="150" Height="30">
                        <TextBlock x:Name="TextAngleGrade6" TextWrapping="Wrap" Text="업데이트 중지" Foreground="#FFFF4600" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="18.667"/>
                    </Button>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Black">
                        <TextBlock x:Name="TextAngleGrade5_Copy4" TextWrapping="Wrap" Text="업데이트 현황 : " Foreground="Yellow" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="64" Margin="12,0,0,0"/>
                        <TextBlock x:Name="TextAngleGrade5_Copy5" TextWrapping="Wrap" Text="1 / 16" Foreground="#FFFF4600" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="64" Margin="12,0,10,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>
