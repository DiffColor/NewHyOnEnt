<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="AndoW_Manager.GroupCommandWindow"
        Title="그룹 명령 실행" Width="800"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        BorderThickness="1" Height="900">
    <Window.Resources>
        <Style x:Key="ButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FF424242"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)" Storyboard.TargetName="border">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF2A446B"/>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)" Storyboard.TargetName="border">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF122540"/>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)" Storyboard.TargetName="border">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF404040"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)" Storyboard.TargetName="contentPresenter">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF7A7A7A"/>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3" Background="#FF473794">
                                <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Btn_default3" TargetType="{x:Type Button}">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition GeneratedDuration="0:0:0.05" To="MouseOver">
                                            <Storyboard/>
                                        </VisualTransition>
                                        <VisualTransition From="MouseOver" GeneratedDuration="0:0:0.05"/>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver"/>
                                    <VisualState x:Name="Pressed"/>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Rectangle x:Name="rectangle" RadiusY="2" RadiusX="2" Stroke="#62000000" Fill="#19FFFFFF" StrokeThickness="0"/>
                            <ContentPresenter HorizontalAlignment="Center" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center" OpacityMask="Black"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="true"/>
                            <Trigger Property="IsDefaulted" Value="true"/>
                            <Trigger Property="IsMouseOver" Value="true"/>
                            <Trigger Property="IsPressed" Value="true"/>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#ADADAD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>

        <Rectangle Fill="#3302133A" Margin="10,10,-5,-5">
            <Rectangle.Effect>
                <BlurEffect Radius="50"/>
            </Rectangle.Effect>
        </Rectangle>

        <Border BorderThickness="1,1,1,1" BorderBrush="#FF4A4A9B" Background="#FFF4F6FB">
            <Grid>
                <!-- 상단 커스텀 타이틀 바 -->

                <Grid Margin="0,35,0,-2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="선택한 플레이어에 명령 실행" Foreground="#FF131933" FontSize="16" FontWeight="Bold" Margin="15,15,15,10"/>

                    <Grid Grid.Row="1" Margin="15,0,15,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="실행할 명령:" Foreground="#FF131933" Margin="0,0,0,5"/>

                        <ComboBox x:Name="CommandComboBox" Grid.Row="1" Padding="5" SelectionChanged="CommandComboBox_SelectionChanged"/>

                        <StackPanel x:Name="OptionsPanel" Grid.Row="2" Margin="0,10,0,0">
                            <TextBlock Text="적용할 플레이리스트:" Foreground="#FF131933" Margin="0,0,0,5" />
                            <ComboBox x:Name="PlaylistComboBox" Padding="5" SelectionChanged="PlaylistComboBox_SelectionChanged"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" Margin="15,0,15,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="SelectedCountText" Text="선택된 플레이어 수: 0대" Foreground="#FF131933" Margin="0,0,0,5"/>

                        <Border Grid.Row="1" BorderThickness="1" Background="#FFD9DFEC" Width="968" HorizontalAlignment="Left">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <WrapPanel x:Name="SelectedPlayersListBox" Margin="0,10,0,10"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="15,0,15,15">
                        <Button x:Name="ExecuteBtn" Width="150" Height="30" Style="{StaticResource ButtonStyle}" Background="#FF225085">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M8,16C12.418,16 16,12.418 16,8 16,3.582 12.418,0 8,0 3.582,0 0,3.582 0,8 0,12.418 3.582,16 8,16z M7,11C7.4,11,7.778,10.842,8.06,10.557L11.708,6.724C12.098,6.329 12.098,5.691 11.708,5.296 11.318,4.901 10.684,4.901 10.294,5.296L7,8.772 5.707,7.296C5.317,6.901 4.684,6.901 4.293,7.296 3.903,7.691 3.903,8.329 4.293,8.724L5.939,10.557C6.222,10.842,6.597,11,6.999,11z" Fill="White" Height="14" Stretch="Fill" StrokeThickness="0" UseLayoutRounding="False" Width="14"/>
                                <TextBlock x:Name="textBlock" TextWrapping="Wrap" Text="실행" Margin="5,0,0,0" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="CloseBtn" Content="닫기" Width="100" Height="30" Style="{DynamicResource Btn_default1}" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
                <Grid x:Name="Window_top" Grid.Row="0" Height="35" VerticalAlignment="Top">
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.96,1.435" StartPoint="-0.027,0.027">
                            <GradientStop Color="Black"/>
                            <GradientStop Color="#FF5252AB" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Rectangle x:Name="DragRect"
                        Grid.Column="0"
                        PreviewMouseLeftButtonDown="DragRect_PreviewMouseLeftButtonDown"
                        StrokeThickness="0"
                        Fill="#005252AB"/>

                    <StackPanel Orientation="Horizontal" Margin="11,0,0,0">
                        <TextBlock Text="일괄 명령 실행"
                            TextWrapping="Wrap"
                            FontFamily="Arial"
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="13.333"
                            FontWeight="Bold"
                            Foreground="#FF9C9BFB"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="0,0,5,0" HorizontalAlignment="Right">
                        <Button x:Name="minBTN_Copy" HorizontalAlignment="Right" Width="38" FontSize="13.333" Foreground="White" Style="{StaticResource Btn_default3}" Margin="1,3" Visibility="Collapsed">
                            <Button.Background>
                                <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                                    <GradientStop Color="#FF071C4D" Offset="0"/>
                                    <GradientStop Color="#FF071C4D" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Grid>
                                <TextBlock x:Name="MaximizedIcon"
                                    Text="□"
                                    FontFamily="Segoe UI Symbol"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="13.333"/>
                                <TextBlock x:Name="WindowIcon"
                                    Text="❐"
                                    FontFamily="Segoe UI Symbol"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="13.333"
                                    Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                        <Button x:Name="minBTN" Content="─" FontFamily="Arial Black" HorizontalAlignment="Right" Width="38" FontSize="13.333" Foreground="White" Style="{StaticResource Btn_default3}" Margin="1,3" Visibility="Collapsed">
                            <Button.Background>
                                <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                                    <GradientStop Color="#FF071C4D" Offset="0"/>
                                    <GradientStop Color="#FF071C4D" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <Button x:Name="ExitBTN" FontFamily="Arial Black" HorizontalAlignment="Right" Width="38" FontSize="13.333"  Foreground="White" Style="{StaticResource Btn_default3}" Margin="1,3">
                            <Button.Background>
                                <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                                    <GradientStop Color="#FF071C4D" Offset="0"/>
                                    <GradientStop Color="#FF071C4D" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Path Data="M9.719,9.719C9.349,10.09,8.747,10.088,8.374,9.716L4.998,6.34 1.622,9.716C1.25,10.088 0.647,10.09 0.277,9.719 -0.094,9.349 -0.092,8.747 0.28,8.374L3.656,4.998 0.28,1.622C-0.092,1.249 -0.094,0.647 0.277,0.277 0.647,-0.094 1.25,-0.092 1.622,0.28L4.998,3.656 8.374,0.28C8.747,-0.092 9.349,-0.094 9.719,0.277 10.09,0.647 10.089,1.249 9.716,1.622L6.34,4.998 9.716,8.374C10.089,8.747,10.09,9.349,9.719,9.719z" Fill="White" Height="9" Stretch="Fill" Stroke="Black" StrokeThickness="0" UseLayoutRounding="False" Width="9"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
