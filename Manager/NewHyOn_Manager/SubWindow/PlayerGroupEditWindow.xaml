<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="AndoW_Manager.PlayerGroupEditWindow"
        Title="플레이어 그룹 편집" Height="900" Width="650" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip" WindowStyle="None" >
    <Window.Resources>
        <Style x:Key="ButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)" Storyboard.TargetName="border">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF2A446B" />
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)" Storyboard.TargetName="border">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF122540" />
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)" Storyboard.TargetName="border">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF404040" />
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)" Storyboard.TargetName="contentPresenter">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF7A7A7A" />
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="border" BorderThickness="1" CornerRadius="3" Background="#FF4B41C5" BorderBrush="#FF32299E">
                                <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnWin_1" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition GeneratedDuration="0" To="MouseOver">
                                            <VisualTransition.GeneratedEasingFunction>
                                                <BackEase EasingMode="EaseOut" />
                                            </VisualTransition.GeneratedEasingFunction>
                                        </VisualTransition>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="rectangle">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed" />
                                    <VisualState x:Name="Disabled" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Rectangle x:Name="rectangle" Fill="#59000000" RadiusY="3" RadiusX="3" Stroke="#660F313F" Opacity="0" />
                            <ContentPresenter OpacityMask="Black" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True" />
                            <Trigger Property="IsDefaulted" Value="True" />
                            <Trigger Property="IsMouseOver" Value="True" />
                            <Trigger Property="IsPressed" Value="True" />
                            <Trigger Property="IsEnabled" Value="False" />
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Rectangle Fill="#3302133A" Margin="10,10,-5,-5">
            <Rectangle.Effect>
                <BlurEffect Radius="50"/>
            </Rectangle.Effect>
        </Rectangle>
        <Border Background="#FFF4F6FB" BorderBrush="#FF4A4A9A" BorderThickness="1,1,1,1">
            <Grid>
                <!-- 상단 윈도우 바 -->
                <Grid x:Name="WinTOP" Grid.Row="0" Height="35" VerticalAlignment="Top">
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="1.0,0.5" StartPoint="0.0,0.5">
                            <GradientStop Color="Black" Offset="0" />
                            <GradientStop Color="#FF5252AB" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="플레이어 그룹 편집"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Foreground="White"
                        FontFamily="Malgun Gothic"
                        FontSize="13.333"
                        FontWeight="Bold" />

                    <Button x:Name="BtnWin_close"
                        Grid.Column="1"
                        Width="26"
                        Height="20"
                        Margin="0,0,6,0"
                        HorizontalAlignment="Right"
                        Style="{DynamicResource BtnWin_1}"
                        Click="BtnWin_close_Click"
                        BorderThickness="1,1,1,2">
                        <Path Data="M9.719,9.719C9.349,10.09,8.747,10.088,8.374,9.716L4.998,6.34 1.622,9.716C1.25,10.088,0.647,10.09,0.277,9.719 -0.094,9.349,-0.092,8.747,0.28,8.374L3.656,4.998 0.28,1.622C-0.092,1.249,-0.094,0.647,0.277,0.277 0.647,-0.094,1.25,-0.092,1.622,0.28L4.998,3.656 8.374,0.28C8.747,-0.092,9.349,-0.094,9.719,0.277 10.09,0.647,10.089,1.249,9.716,1.622L6.34,4.998 9.716,8.374C10.089,8.747,10.09,9.349,9.719,9.719z"
                            Fill="White"
                            Height="10"
                            Width="10"
                            Stretch="Fill"
                            Stroke="Black"
                            StrokeThickness="0"
                            UseLayoutRounding="False"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center" />
                    </Button>
                </Grid>

                <!-- 그룹 기본 정보 영역 -->
                <Grid Margin="20,45,20,0" Height="146" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="그룹 이름" Foreground="Black" Margin="0,0,0,5" />
                        <TextBox x:Name="GroupNameTextBox"
                            FontSize="20"
                            Padding="5"
                            Background="White"
                            Foreground="#FF0F1535"
                            BorderBrush="#FFC5C5C5"
                            BorderThickness="1" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="그룹 로고" Foreground="Black" Margin="0,0,0,5" />
                        <Border Height="100"
                            Background="White"
                            BorderBrush="#FFBBBBBB"
                            BorderThickness="1">
                            <Grid>
                                <TextBlock x:Name="LogoPreviewText"
                                    Text="로고 없음"
                                    Foreground="#FF7A7A7A"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                                <Image x:Name="LogoPreviewImage"
                                    Stretch="Uniform"
                                    Margin="5"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,5,0,0">
                            <Button x:Name="SelectLogoBtn"
                                Content="로고 선택"
                                Padding="5,2"
                                Style="{DynamicResource ButtonStyle2}"
                                Width="100"
                                Height="20" Background="White" />
                            <Button x:Name="ClearLogoBtn"
                                Content="로고 지우기"
                                Padding="5,2"
                                Style="{DynamicResource Btn_default1}"
                                Width="100"
                                Margin="5,0,0,0"
                                IsEnabled="False"
                                Height="20" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- 플레이어 목록 영역 -->
                <Grid Margin="20,206,20,50">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,0,0,5"><Run Text="플레이어 할당" Foreground="Black" FontWeight="SemiBold" FontSize="14" /><Run Text=" "/><Run Text=" - " Foreground="#FF1A2B6D" /><Run Text=" "/><Run x:Name="SelectedPlayersCountText" Text="0명 선택됨" Foreground="#FF1A2B6D" /></TextBlock>

                    <Grid Grid.Row="1" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="플레이어를 선택하면 해당 그룹으로 할당됩니다."
                            Foreground="#FF4E4E4E"
                            VerticalAlignment="Center"
                            FontSize="12" />

                        <StackPanel Orientation="Horizontal" Grid.Column="1">
                            <Button x:Name="SelectAllBtn"
                                Padding="8,3"
                                Style="{DynamicResource Btn_defaultSW}"
                                Margin="0,0,5,0"
                                ToolTip="모든 플레이어 선택"
                                Width="80"
                                Height="20">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="전체" FontWeight="Bold" Margin="0,0,5,0" />
                                    <TextBlock Text="선택" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="DeselectAllBtn"
                                Padding="8,3"
                                Style="{DynamicResource Btn_defaultSW}"
                                ToolTip="모든 플레이어 선택 해제"
                                Width="80"
                                Height="20">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="전체" FontWeight="Bold" Margin="0,0,5,0" />
                                    <TextBlock Text="해제" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2"
                        Background="#FFD9DFEC"
                        BorderThickness="1" CornerRadius="4,4,4,4" BorderBrush="#FFC0C7D8">
                        <ScrollViewer x:Name="PlayersScrollViewer"
                            Style="{StaticResource ModernScrollViewer}"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="PlayersListBox" Margin="15,15,15,15">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel ItemWidth="160" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- 하단 버튼 영역 -->
                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,10" Height="30" VerticalAlignment="Bottom">
                    <Button x:Name="SaveBtn"
                        Width="100"
                        Height="30"
                        Style="{StaticResource ButtonStyle}"
                        Margin="0,0,10,0"
                        Background="#FF225085">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="textBlock"
                                Foreground="White"
                                Text="저장"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="CloseBtn"
                        Content="취소"
                        Width="100"
                        Height="30"
                        Style="{DynamicResource Btn_default1}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
