<Window x:Class="TurtleTools.DbLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="연결 확인"
        Height="180"
        Width="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#FF1E1E1E"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#FF2C2C2C" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#FF3D3D3D">
        <StackPanel>
            <TextBlock x:Name="TitleTextBlock"
                       Text="연결 확인 중..."
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#FFFAFAFA"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />
            <TextBlock x:Name="MessageTextBlock"
                       Text="연결 상태를 확인하고 있습니다."
                       FontSize="13"
                       Foreground="#FFCFCFCF"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
            <ProgressBar IsIndeterminate="True" Height="14" Margin="0,18,0,0" />
        </StackPanel>
    </Border>
</Window>
