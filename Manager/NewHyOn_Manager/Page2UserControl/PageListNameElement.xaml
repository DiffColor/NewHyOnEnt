<UserControl x:Class="AndoW_Manager.PageListNameElement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="583" Height="30" Margin="10,0,10,0">
    <UserControl.Resources>
        <Style x:Key="Btn_defaultSW_Local" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition From="Pressed" GeneratedDuration="0:0:0.3"/>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF08193B"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF00071A"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[2].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF051A45"/>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[2].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF000E1B"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF000914"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#FF000D35"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Stroke).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#68000000"/>
                                            </ColorAnimationUsingKeyFrames>
                                            <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Stroke).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
                                                <EasingColorKeyFrame KeyTime="0" Value="#19000000"/>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Rectangle x:Name="rectangle" RadiusY="0" RadiusX="0">
                                <Rectangle.Fill>
                                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                        <GradientStop Color="#FF0C0C0C" Offset="0.667"/>
                                        <GradientStop Color="#FF252525"/>
                                        <GradientStop Color="#FF121212" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.Stroke>
                                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                        <GradientStop Color="#59000000" Offset="0"/>
                                        <GradientStop Color="#19FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Stroke>
                            </Rectangle>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True"/>
                            <Trigger Property="IsDefaulted" Value="True"/>
                            <Trigger Property="IsMouseOver" Value="True"/>
                            <Trigger Property="IsPressed" Value="True"/>
                            <Trigger Property="IsEnabled" Value="False"/>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid x:Name="rootGrid">
        <Grid x:Name="LayoutGrid">
            <Grid.RowDefinitions>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ContextMenu>
                <ContextMenu x:Name="DisplayCotextMenu">
                    <!--<MenuItem Header="미리보기" ToolTip="컨텐츠의 미리보기를 실행합니다."  x:Name="MC_PreviewContents"/>-->
                    <MenuItem Header="복사하기" ToolTip="플레이리스트 항목을 복사합니다."  x:Name="MC_CopyPlayList"/>
                    <Separator x:Name="Sep1" Visibility="Collapsed" />
                    <MenuItem Visibility="Collapsed" Header="USB로 데이터 추출" ToolTip="플레이리스트 업데이트를 위해 USB로 데이터를 추출합니다." x:Name="MC_CopyToUSB"/>
                    <Separator x:Name="Sep2" Visibility="Collapsed" />
                    <MenuItem Visibility="Collapsed" Header="USB데이터 정리" ToolTip="USB에 누적된 컨텐츠 파일들을 정리합니다."  x:Name="MC_CleanUSB"/>
                </ContextMenu>
            </Grid.ContextMenu>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="45"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>
            <Rectangle Fill="#4C4C4C8A" Grid.ColumnSpan="4" Margin="0" Grid.RowSpan="2"/>
            <Rectangle Fill="#19898989" Margin="4,0" Grid.RowSpan="2"/>
            <Border x:Name="SelectBorder_Copy" BorderBrush="#FF455E99" BorderThickness="26,2,2,2" Grid.ColumnSpan="4" Grid.RowSpan="2" d:IsHidden="True"/>
            <Border x:Name="SelectBorder" BorderThickness="0" Grid.ColumnSpan="4" Grid.RowSpan="2" d:IsHidden="True">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#33221B54" Offset="1"/>
                        <GradientStop Color="#1EFFFFFF"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <TextBlock x:Name="TextBlockOrderingNumber" TextWrapping="Wrap" Text="01" FontFamily="Malgun Gothic" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5.37,2.708"/>
            <TextBlock x:Name="TextBlockPageName" TextTrimming="CharacterEllipsis"  Grid.Column="1" TextWrapping="NoWrap" Text="Name" Foreground="White" FontFamily="Malgun Gothic" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="13.333" MaxWidth="426" Margin="5,0,0,0"/>
            <TextBlock x:Name="ExitTextBlock" TextWrapping="Wrap" Text="X" FontFamily="Malgun Gothic" FontSize="13.333" Foreground="Gray" Grid.Column="3" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="7.158,1.898"/>
            <TextBlock x:Name="TextBlockPageName_Copy" Grid.Column="1" TextWrapping="NoWrap" Text="09:00" Foreground="White" FontFamily="Malgun Gothic" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,2" FontSize="10.667"/>
            <TextBlock x:Name="TextBlockPageName_Copy1" TextWrapping="NoWrap" Text="이름 :" Foreground="#FFA0A0A0" FontFamily="Malgun Gothic" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,12.708,3,12.708" Visibility="Hidden" Grid.RowSpan="2" Grid.Column="2"/>
            <Button x:Name="BTN0DO_Copy1" Style="{DynamicResource ButtonDefault2}"  Height="22" Width="40" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="2" Background="White" Margin="0,0,4,0">
                <TextBlock x:Name="TextAngleGrade1" TextWrapping="Wrap" Text="편집" Foreground="#FF183058" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="10.667"/>
            </Button>
            <Rectangle Fill="#4C000000" Grid.ColumnSpan="4" Margin="0" Height="1" VerticalAlignment="Bottom"/>
            <Rectangle Fill="#19FFFFFF" Grid.ColumnSpan="4" Margin="0" Height="1" VerticalAlignment="Top"/>
        </Grid>
    </Grid>
</UserControl>
