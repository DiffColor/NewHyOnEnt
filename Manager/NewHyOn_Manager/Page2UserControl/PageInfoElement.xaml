<UserControl x:Class="AndoW_Manager.PageInfoElement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="34" d:DesignWidth="583" Height="30">
	<UserControl.Resources>
		<Style x:Key="Btn_defaultSW_Local" TargetType="{x:Type Button}">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type Button}">
						<Grid>
							<VisualStateManager.VisualStateGroups>
								<VisualStateGroup x:Name="CommonStates">
									<VisualStateGroup.Transitions>
										<VisualTransition From="Pressed" GeneratedDuration="0:0:0.3"/>
									</VisualStateGroup.Transitions>
									<VisualState x:Name="Normal"/>
									<VisualState x:Name="MouseOver">
										<Storyboard>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF08193B"/>
											</ColorAnimationUsingKeyFrames>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF00071A"/>
											</ColorAnimationUsingKeyFrames>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[2].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0:0:0.2" Value="#FF051A45"/>
											</ColorAnimationUsingKeyFrames>
										</Storyboard>
									</VisualState>
									<VisualState x:Name="Pressed">
										<Storyboard>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[2].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="#FF000E1B"/>
											</ColorAnimationUsingKeyFrames>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="#FF000914"/>
											</ColorAnimationUsingKeyFrames>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="#FF000D35"/>
											</ColorAnimationUsingKeyFrames>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Stroke).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="#68000000"/>
											</ColorAnimationUsingKeyFrames>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Stroke).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="#19000000"/>
											</ColorAnimationUsingKeyFrames>
										</Storyboard>
									</VisualState>
									<VisualState x:Name="Disabled"/>
								</VisualStateGroup>
							</VisualStateManager.VisualStateGroups>
							<Rectangle x:Name="rectangle" RadiusY="0" RadiusX="0">
								<Rectangle.Fill>
									<LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
										<GradientStop Color="#FF0C0C0C" Offset="0.667"/>
										<GradientStop Color="#FF252525"/>
										<GradientStop Color="#FF121212" Offset="1"/>
									</LinearGradientBrush>
								</Rectangle.Fill>
								<Rectangle.Stroke>
									<LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
										<GradientStop Color="#59000000" Offset="0"/>
										<GradientStop Color="#19FFFFFF" Offset="1"/>
									</LinearGradientBrush>
								</Rectangle.Stroke>
							</Rectangle>
							<ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
						</Grid>
						<ControlTemplate.Triggers>
							<Trigger Property="IsFocused" Value="True"/>
							<Trigger Property="IsDefaulted" Value="True"/>
							<Trigger Property="IsMouseOver" Value="True"/>
							<Trigger Property="IsPressed" Value="True"/>
							<Trigger Property="IsEnabled" Value="False"/>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>
	<Grid x:Name="rootGrid">
		<Grid x:Name="LayoutGrid">
			<Grid.ContextMenu>
				<ContextMenu x:Name="DisplayCotextMenu">
                    <!--<MenuItem Header="미리보기" ToolTip="컨텐츠의 미리보기를 실행합니다."  x:Name="MC_PreviewContents"/>-->
					<MenuItem Header="복사하기" ToolTip="페이지 항목을 복사합니다."  x:Name="MC_CopyPage"/>
				</ContextMenu>
			</Grid.ContextMenu>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="26"/>
				<ColumnDefinition/>
				<ColumnDefinition Width="24.5"/>
			</Grid.ColumnDefinitions>
			<Rectangle Fill="#7F000000" Grid.ColumnSpan="4" Margin="0" Height="0.5" VerticalAlignment="Bottom"/>
			<Rectangle x:Name="BackRectangle" Fill="#19686868" Grid.Column="1" Margin="0"/>
			<Border x:Name="SelectBorder" BorderBrush="#FF0DB8CE" BorderThickness="1" Grid.ColumnSpan="4" d:IsHidden="True" Visibility="Hidden"/>
			<TextBlock x:Name="TextBlockOrderingNumber" TextWrapping="Wrap" Text="01" FontFamily="Malgun Gothic" Foreground="#FFC2C2C2" HorizontalAlignment="Center" Width="15.26" VerticalAlignment="Center"/>
			<TextBlock x:Name="ExitTextBlock" TextWrapping="Wrap" Text="X" VerticalAlignment="Center" FontFamily="Malgun Gothic" FontSize="13.333" Foreground="#FF4A4A4A" Grid.Column="2" FontWeight="Bold" Margin="6.158,1.398,8.158,5.398"/>
			<Grid Grid.Column="1" Margin="0" VerticalAlignment="Center">
				<Grid.ColumnDefinitions>
					<ColumnDefinition/>
					<ColumnDefinition Width="60"/>
					<ColumnDefinition Width="210"/>
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition Height="25"/>
				</Grid.RowDefinitions>
                <TextBlock x:Name="TextBlockPageName" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Text="Name" Foreground="{DynamicResource Color_font001}" FontFamily="Malgun Gothic" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,5,0,5" MaxWidth="248"/>
				<Grid x:Name="DisplayTimeGrid" Grid.Column="2">
					<TextBlock x:Name="TextBlockPageName_Copy2" TextWrapping="NoWrap" Text="00:00:00" Foreground="#FF1AAAC1" FontFamily="Malgun Gothic" HorizontalAlignment="Left" VerticalAlignment="Center"/>
					<Button x:Name="BTN0DO_Copy3" Style="{DynamicResource Btn_defaultSW}" Height="22" Width="50" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,13,0">
						<TextBlock x:Name="TextAngleGrade4" TextWrapping="Wrap" Text="편집" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="13.333"/>
					</Button>
				</Grid>
				<Grid x:Name="EditPlayTimeGrid" Grid.Column="2" Visibility="Collapsed">
					<StackPanel HorizontalAlignment="Left" Width="158.5" Orientation="Horizontal">
						<ComboBox x:Name="scrollSpeedComboBox_Copy1" ItemsSource="{StaticResource TimeItems}" VerticalAlignment="Center" Height="20" Width="45" HorizontalAlignment="Left"/>
						<ComboBox x:Name="scrollSpeedComboBox_Copy" ItemsSource="{StaticResource TimeItems}" VerticalAlignment="Center" Height="20" Width="45" HorizontalAlignment="Left" Margin="3,0,0,0"/>
						<ComboBox x:Name="scrollSpeedComboBox_Copy2" ItemsSource="{StaticResource TimeItems}" VerticalAlignment="Center" Height="20" Width="45" HorizontalAlignment="Left" Margin="3,0,0,0"/>
					</StackPanel>
					<Button x:Name="BTN0DO_Copy1" Style="{DynamicResource Btn_defaultSW}" Height="22" Width="50" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,13,0">
						<TextBlock x:Name="TextAngleGrade1" TextWrapping="Wrap" Text="저장" Foreground="#FFFF372E" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="13.333"/>
					</Button>
				</Grid>
				<TextBlock x:Name="TextBlockPageName_Copy" TextWrapping="NoWrap" Text="재생시간 :" Foreground="#FF333333" FontFamily="Malgun Gothic" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="1"/>
			</Grid>
		</Grid>
	</Grid>
</UserControl>
