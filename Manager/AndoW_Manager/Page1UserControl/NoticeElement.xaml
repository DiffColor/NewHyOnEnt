<UserControl x:Class="HyonManager.SubElement.NoticeElement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300" Height="23">
    <Grid x:Name="rootGrid">
        <Grid x:Name="LayoutGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="24.5"/>
            </Grid.ColumnDefinitions>
            <Rectangle RadiusX="3" RadiusY="3" Fill="#AD001E3C" Grid.ColumnSpan="6" Margin="0,0,0,2"/>
            <Rectangle x:Name="BackRectangle" Fill="#B20080FF" Grid.Column="1" d:LayoutOverrides="GridBox" Margin="0,0,0,2"/>
            <TextBlock x:Name="TextBlockOrderingNumber" TextWrapping="Wrap" Text="01" FontFamily="Verdana" Foreground="#FFC2C2C2" HorizontalAlignment="Center" Margin="0,3.208,0,5.208" d:LayoutOverrides="Height"/>
            <TextBlock x:Name="TextBlockPageName" Grid.Column="1" TextWrapping="NoWrap" Text="Name" Foreground="White" FontFamily="Verdana" d:LayoutOverrides="Height, GridBox" HorizontalAlignment="Left" Margin="4,3.208,0,5.208"/>
            <TextBlock x:Name="ExitTextBlock" TextWrapping="Wrap" Text="X" FontFamily="Verdana" FontSize="13.333" Foreground="Gray" Grid.Column="2" d:LayoutOverrides="Width, Height, GridBox" FontWeight="Bold" Margin="6.158,1.398,8.158,5.398"/>
        </Grid>
    </Grid>
</UserControl>
