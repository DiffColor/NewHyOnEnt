<UserControl x:Class="AndoW_Manager.ScrollTextForEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             SizeChanged="UserControl_SizeChanged"
             d:DesignHeight="100" d:DesignWidth="600">
    <Grid>
        <Grid.ContextMenu>
            <!--<ContextMenu x:Name="DisplayCotextMenu">
                <MenuItem Header="Delete" ToolTip="Delete"  x:Name="ElementDelete"/>
                <MenuItem Header="Bring To Front" ToolTip="Bring To Front"  x:Name="MenuBringToFront"/>
                <MenuItem Header="Move To Back" ToolTip="Move To Back"  x:Name="MenuBringToBack"/>
                <MenuItem Header="Bring To Front One Step" ToolTip="Bring To Front One Step"  x:Name="MenuBringToFrontOneStep"/>
                <MenuItem Header="Move To Back One Step" ToolTip="Move To Back One Step"  x:Name="MenuBringToBackOneStep"/>
            </ContextMenu>-->
           <ContextMenu x:Name="DisplayCotextMenu">
                <MenuItem Header="삭제" ToolTip="객체를 삭제합니다.."  x:Name="ElementDelete"/>
                <MenuItem Header="맨앞으로" ToolTip="객체를 맨 앞에 배치합니다."  x:Name="MenuBringToFront"/>
                <MenuItem Header="맨뒤로" ToolTip="객체를 맨 뒤에 배치합니다."  x:Name="MenuBringToBack"/>
                <MenuItem Header="한단계 앞으로" ToolTip="객체를 한단계 앞에 배치합니다."  x:Name="MenuBringToFrontOneStep"/>
                <MenuItem Header="한단계 뒤로" ToolTip="객체를 한단계 뒤에 배치합니다."  x:Name="MenuBringToBackOneStep"/>
            </ContextMenu> <!---->
        </Grid.ContextMenu>
        <Grid x:Name="LayoutRoot" Margin="0" Background="#FF151515">
    		<!--<Button x:Name="LftBTN" Style="{DynamicResource LFD}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#FF43BA22" OpacityMask="Black" d:LayoutOverrides="HorizontalAlignment, VerticalAlignment">-->
    		<!--<Button x:Name="LftBTN" Style="{DynamicResource LFD}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#FF43BA22" OpacityMask="Black" d:LayoutOverrides="HorizontalAlignment, VerticalAlignment">-->
			<!--<Button x:Name="LftBTN" Style="{DynamicResource LFD}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#FF43BA22" OpacityMask="Black" d:LayoutOverrides="HorizontalAlignment, VerticalAlignment">-->
		<!--<Button x:Name="LftBTN" Style="{DynamicResource LFD}" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="#FF43BA22" OpacityMask="Black" d:LayoutOverrides="HorizontalAlignment, VerticalAlignment">-->
    		<Border x:Name="BoundaryBorder" BorderThickness="5" Grid.ColumnSpan="3" Grid.RowSpan="5">
    			<Border.BorderBrush>
    				<LinearGradientBrush EndPoint="0.798,0.804" StartPoint="0.202,0.196">
    					<GradientStop Color="#FF181818" Offset="1"/>
    					<GradientStop Color="Black"/>
    				</LinearGradientBrush>
    			</Border.BorderBrush>
    		</Border>
    		<Border x:Name="BoundaryBorder2" BorderThickness="4" Margin="3" BorderBrush="#FF292929"/>
    		<Border BorderThickness="1" Margin="0">
    			<Border.BorderBrush>
    				<LinearGradientBrush EndPoint="0.995,1.006" StartPoint="0.309,0.267">
    					<GradientStop Color="#CC000000" Offset="1"/>
    					<GradientStop Color="#26FFFFFF"/>
    					<GradientStop Color="#FF423D3D" Offset="0.852"/>
    				</LinearGradientBrush>
    			</Border.BorderBrush>
                <TextBlock x:Name="pxTBox" Height="48" HorizontalAlignment="Right" TextAlignment="Right" FontSize="32" TextWrapping="Wrap" Foreground="LightCoral" Text="1920 x 1080" VerticalAlignment="Top" Width="189" Margin="0,9,18,0"/>
            </Border>
    		<Grid VerticalAlignment="Center" HorizontalAlignment="Center">
    			<Grid.ColumnDefinitions>
    				<ColumnDefinition Width="19*"/>
    				<ColumnDefinition Width="13*"/>
    			</Grid.ColumnDefinitions>
    			<Grid.RowDefinitions>
    				<RowDefinition/>
    				<RowDefinition/>
    			</Grid.RowDefinitions>
    			<TextBlock x:Name="TextDisplayName" TextWrapping="Wrap" Text="자막" FontSize="32" Foreground="White" Margin="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Malgun Gothic" />
    			<TextBlock x:Name="TextInputChannelName" TextWrapping="Wrap" Text="    자막" FontSize="32" Foreground="#FFD43A00" Margin="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Malgun Gothic" Grid.Column="1" />
    		</Grid>
    		<Rectangle x:Name="resizingSpotRect" Width="40" Height="40" VerticalAlignment="Bottom" HorizontalAlignment="Right" d:LayoutOverrides="HorizontalAlignment, VerticalAlignment" Cursor="SizeNWSE" Margin="0,0,5,5">
    			<Rectangle.Fill>
    				<LinearGradientBrush EndPoint="0.979,0.971" StartPoint="0.146,0.146">
    					<GradientStop Offset="0.655" Color="#00000000"/>
    					<GradientStop Color="Red" Offset="0.994"/>
    					<GradientStop Color="#FF353535" Offset="0.689"/>
    					<GradientStop Color="#FF101010" Offset="0.732"/>
    					<GradientStop Color="#FF454545" Offset="0.811"/>
    					<GradientStop Color="#FE000000" Offset="0.856"/>
    					<GradientStop Color="#FF0E0E0E" Offset="0.794"/>
    					<GradientStop Color="#FEC6C6C6" Offset="0.852"/>
    				</LinearGradientBrush>
    			</Rectangle.Fill>
    		</Rectangle>
    	</Grid>
    </Grid>
</UserControl>
