<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             xmlns:AndoW_Manager="clr-namespace:AndoW_Manager" 
			 x:Class="AndoW_Manager.Page3" 
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920" Background="#FFF4F6FB">
    <UserControl.Resources>
    </UserControl.Resources>
    <Grid x:Name="LayoutGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="ContentsListGrid_Copy2">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="8"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Visibility="Collapsed">
                <TextBlock
					VerticalAlignment="Center" Text="신규 플레이어 이름:" TextWrapping="Wrap" HorizontalAlignment="Left" FontFamily="Malgun Gothic" Foreground="#FFB6B6B6" Margin="192,0,6,0"/>
                <TextBox x:Name="TextBoxNewPlayerName_Copy" TextWrapping="NoWrap" FontFamily="Malgun Gothic" Background="{DynamicResource color_textBoxFill001}" Style="{DynamicResource TextBoxStyle1}" Foreground="White" Width="215" VerticalAlignment="Center" Height="25" BorderBrush="{DynamicResource color_textBoxFill001}" BorderThickness="0"/>
                <Button x:Name="BTN0DO_Copy3" Style="{DynamicResource power}" Height="28" VerticalAlignment="Center" Margin="5,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M1.5768099,10.9948 L1.5768099,19.1484 13.729199,19.1484 13.729199,10.9948 z M0,9.4173004 L15.3047,9.4173004 15.3047,20.7227 0,20.7227 z M17.2005,0 L19.0013,0 19.0013,5.7525603 24.667898,5.7525603 24.667898,7.5533401 19.0013,7.5533401 19.0013,13.3047 17.2005,13.3047 17.2005,7.5533401 11.531299,7.5533401 11.531299,5.7525603 17.2005,5.7525603 z" Fill="{DynamicResource Color_font003}" Height="14" Stretch="Fill" Width="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="11,0,5,0"/>
                        <TextBlock x:Name="TextAngleGrade3" TextWrapping="Wrap" Text="플레이어 추가" Foreground="{DynamicResource Color_font003}" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" Margin="0,0,11,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <Border Grid.Row="2" Grid.Column="0" BorderThickness="1" Margin="2">
                <ScrollViewer x:Name="PlayerListScrollViewer" Style="{StaticResource ModernScrollViewer}" Background="#FF252525" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="PlayerListBox" Background="Transparent" Margin="40,3,40,40" HorizontalAlignment="Center"
								LayoutUpdated="PlayerListBox_LayoutUpdated" Drop="PlayerListBox_Drop" BorderThickness="0"
								SelectionMode="Extended" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
								dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True" dd:DragDrop.UseDefaultEffectDataTemplate="True" >
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Resources>
                            <Style TargetType="{x:Type ListBoxItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                            <Border x:Name="Bd"
													BorderBrush="{TemplateBinding BorderBrush}"
													BorderThickness="{TemplateBinding BorderThickness}"
													Background="{TemplateBinding Background}"
													SnapsToDevicePixels="true">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
																SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
																VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="Selector.IsSelectionActive" Value="False" />
                                                        <Condition Property="IsSelected" Value="True" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" TargetName="Bd" Value="Transparent" />
                                                    <Setter Property="BorderBrush" TargetName="Bd" Value="#26A0DA" />
                                                    <!--<Setter Property="BorderThickness" TargetName="Bd" Value="2" />-->
                                                </MultiTrigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="Selector.IsSelectionActive" Value="True" />
                                                        <Condition Property="IsSelected" Value="True" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" TargetName="Bd" Value="Transparent" />
                                                    <Setter Property="BorderBrush" TargetName="Bd" Value="#26A0DA" />
                                                    <!--<Setter Property="BorderThickness" TargetName="Bd" Value="2" />-->
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Margin" Value="7"/>
                            </Style>
                        </ListBox.Resources>
                    </ListBox>
                </ScrollViewer>
            </Border>
            <StackPanel Orientation="Horizontal" Margin="0,0,50,0" HorizontalAlignment="Right" Grid.Column="0" VerticalAlignment="Bottom">
                <Button x:Name="BTN0DO_Copy9" Visibility="Collapsed" Style="{DynamicResource Btn_defaultSW}" Width="110" Height="30" Margin="0,2.5">
                    <TextBlock x:Name="TextAngleGrade10" TextWrapping="Wrap" Foreground="#FFFFAE21" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" Text="처음페이지"/>
                </Button>
                <Button x:Name="BTN0DO_Copy8" Visibility="Collapsed" Style="{DynamicResource Btn_defaultSW}" Width="110" Height="30" Margin="0,2.5">
                    <TextBlock x:Name="TextAngleGrade9" TextWrapping="Wrap" Foreground="#FFEBFF21" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" Text="다음페이지"/>
                </Button>
