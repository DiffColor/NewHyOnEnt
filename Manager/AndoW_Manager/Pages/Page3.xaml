                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>


        <!-- 그룹 관리 영역 -->
        <Grid x:Name="GroupManagementGrid" Width="220" Background="#FFDEE4EF" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 구분선 추가 -->

            <!-- 헤더 배경 강화 -->

            <!-- 그룹 스크롤뷰 테두리 강화 -->
            <Border x:Name="GroupScrollBorder" Grid.Row="1" BorderThickness="0,0,0,1" Margin="0,8,0,0">
                <ScrollViewer x:Name="GroupScrollViewer" Style="{StaticResource ModernScrollViewer}" Background="White" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="GroupButtonsPanel" Margin="10,5,10,20">
                        <!-- 그룹 버튼들이 동적으로 추가됩니다 -->
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <StackPanel Margin="15,5,15,0" VerticalAlignment="Bottom">
                <Button x:Name="AddGroupBtn" Style="{DynamicResource ButtonStyle2}" Height="34">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M8,16 C12.4183,16 16,12.4183 16,8 C16,3.58172 12.4183,0 8,0 C3.58172,0 0,3.58172 0,8 C0,12.4183 3.58172,16 8,16 z M4,8 L12,8 M8,4 L8,12" Stroke="White" StrokeThickness="1.5" Height="15" Width="15" Stretch="Uniform" Margin="0,0,8,0"/>
                        <TextBlock Text="새 그룹 추가" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
