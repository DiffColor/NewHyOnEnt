                    </StackPanel>
                </Button>
                <Button x:Name="UpdateThrottleSettingsBtn" Click="UpdateThrottleSettingsBtn_Click" Style="{DynamicResource Btn_defaultSW}" Width="170" Height="30" Margin="7,0,0,3">
                    <TextBlock TextWrapping="Wrap" Text="다운로드 제한 설정" Foreground="#FF3F51B5" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="12"/>
                </Button>
