                    <StackPanel Orientation="Horizontal">
                        <Path Data="M16.953,2.543C16.953,2.774,16.837,3.005,16.607,3.236Q8.765,11.211 8.765,11.211 7.265,12.714 7.265,12.714C7.035,12.83 6.804,12.945 6.458,12.945 6.227,12.945 5.997,12.83 5.766,12.714Q4.267,11.211 4.267,11.211 0.346,7.166 0.346,7.166C0.115,7.05 0,6.819 0,6.473 0,6.126 0.115,5.895 0.346,5.779Q1.845,4.277,1.845,4.277C2.076,4.045 2.306,3.93 2.537,3.93 2.883,3.93 3.114,4.045 3.344,4.277Q6.458,7.513 6.458,7.513 13.723,0.231 13.723,0.231C13.839,0.116 14.069,0 14.415,0 14.646,0 14.992,0.116 15.107,0.231Q16.607,1.734,16.607,1.734C16.837,1.965,16.953,2.196,16.953,2.543z" Fill="#FF5F6FC5" Height="11" Stretch="Fill" Stroke="Black" StrokeThickness="0" UseLayoutRounding="False" Width="14" Margin="0,0,4,0"/>
