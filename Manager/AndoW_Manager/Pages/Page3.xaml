                    <StackPanel Orientation="Horizontal">
                        <Path Data="M14.8528,14.890699 L23.931,16.290499 21.5351,18.684999 26.4232,23.573 23.558599,26.4377 18.6706,21.5495 16.2514,23.9688 z M11.57162,14.8686 L10.173217,23.9454 7.7773533,21.5495 2.8894053,26.4377 0.024719238,23.573 4.9126682,18.684999 2.493474,16.2658 z M23.535103,0 L26.398401,2.8659098 21.510402,7.7540894 23.931002,10.171899 14.852801,11.569099 16.251401,2.4922798 18.647101,4.8880296 z M2.8645601,0 L7.7539101,4.8880301 10.1732,2.4688401 11.5703,11.5483 2.4921904,10.148601 4.8867207,7.7514 0,2.8633699 z" Fill="White" Height="12" Stretch="Fill" Width="12" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TextAngleGrade2" TextWrapping="Wrap" Text="플레이어 접기" Foreground="#FFA6A6A6" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BTN0DO_Copy2" Style="{DynamicResource Btn_defaultSW}" Width="130" Height="30" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M17.7267,14.886601 L22.614699,19.7734 25.0327,17.355499 26.429699,26.429699 17.354199,25.032499 19.75,22.636601 14.8633,17.75 z M8.67975,14.8633 L11.5443,17.726574 6.65625,22.613232 9.0756197,25.033711 0,26.4296 1.39853,17.355478 3.7917204,19.749958 z M26.4298,0.001281932 L25.030087,9.0767958 22.636867,6.6810491 17.750025,11.569081 14.8855,8.7031757 19.772242,3.8164036 17.354222,1.3972177 z M0,0 L9.0756197,1.39722 6.6810894,3.7928802 11.5677,8.68106 8.7032199,11.5443 3.8151894,6.65753 1.3971901,9.0768101 z" Fill="White" Height="12" Stretch="Fill" Width="12" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TextAngleGrade4" TextWrapping="Wrap" Text="플레이어 펼치기" Foreground="#FFA6A6A6" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BTN0DO_Copy" Style="{DynamicResource Btn_defaultSW}" Width="170" Height="30"  Margin="7,0,0,3">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M6.6016202,10.72 L20.980419,10.72 20.980419,12.12173 6.6016202,12.12173 z M6.6016202,7.5618299 L20.980419,7.5618299 20.980419,8.9641103 6.6016202,8.9641103 z M6.888,4.5194696 L6.888,6.8879994 4.48175,6.8879994 4.48175,17.693998 23.076799,17.693998 23.076799,4.5194696 15.9531,4.5194696 z M0,0 L6.888,0 6.888,2.9446398 15.9531,2.9446398 24.6511,2.9446398 24.6511,19.269499 2.90747,19.269499 2.90747,6.8879994 0,6.8879994 z" Fill="#FF3F51B5" Height="16" Stretch="Fill" Width="19" Margin="0,0,6,2"/>
                        <TextBlock x:Name="TextAngleGrade1" TextWrapping="Wrap" FontSize="12" Text="플레이어정보 관리" Foreground="#FF3F51B5" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic"/>
                    </StackPanel>
                </Button>
                <Button x:Name="EditPListBtn" Click="EditPListBtn_Click" Style="{DynamicResource Btn_defaultSW}" Width="170" Height="30" Margin="7,0,0,3">
                    <TextBlock TextWrapping="Wrap" Text="플레이리스트 관리" Foreground="#FF3F51B5" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="12"/>
                </Button>
                <Button x:Name="BatchUpdateBtn" Click="BatchUpdateBtn_Click" Style="{DynamicResource Btn_defaultSW}" Width="170" Height="30" Margin="7,0,0,3" Visibility="Collapsed">
                    <TextBlock TextWrapping="Wrap" Text="화면구성 일괄업데이트" Foreground="#FF3F51B5" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="12"/>
                </Button>
