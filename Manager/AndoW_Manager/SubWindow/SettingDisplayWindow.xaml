        			</Button>
        		</StackPanel>
        		<StackPanel Orientation="Horizontal" Grid.Row="1">
        			<TextBlock x:Name="testTextBlk_Copy5" TextWrapping="Wrap" Text="Source Type :" FontFamily="Malgun Gothic" FontSize="13.333" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FFC3C3C3" Margin="6,0,0,0"/>
        			<ComboBox x:Name="regMonthComboBox_Copy5" VerticalAlignment="Center" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" HorizontalAlignment="Left" Width="156" Margin="3,0,0,0"/>
        			<Button x:Name="BTN0DO_Copy6" Style="{DynamicResource Btn_default2}" Width="40" Margin="9,4,0,4" Height="23">
