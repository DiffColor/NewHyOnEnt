                        	<GradientStop Color="#2EEBEBEB" Offset="0.5"/>
                        	<GradientStop Color="#15DDDDDD" Offset="0.507"/>
                        	<GradientStop Color="#13CDCDCD" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </StackPanel>
