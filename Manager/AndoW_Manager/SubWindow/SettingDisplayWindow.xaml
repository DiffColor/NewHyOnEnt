                    <TextBlock.Foreground>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FFAFAFAF" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.5"/>
                    </TextBlock.Effect></TextBlock>
                <TextBlock TextWrapping="Wrap" FontFamily="Malgun Gothic" FontSize="13.333" FontWeight="Bold" Text="Client" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="11,4.953,0,4.953">
                    <TextBlock.Foreground>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FFAFAFAF" Offset="1"/>
                            <GradientStop Color="#FF70FF2E"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.5"/>
                    </TextBlock.Effect></TextBlock>
            </StackPanel>
        </Grid>
