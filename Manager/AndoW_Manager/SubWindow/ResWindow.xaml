<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AndoW_Manager"
        xmlns:tt="clr-namespace:TurtleTools" Loaded="Window_Loaded" Closing="Window_Closing"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="AndoW_Manager.ResWindow"
        Title="알림창" SizeToContent="WidthAndHeight" MinWidth="460" MinHeight="140" WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize">
    <Grid Height="156">
        <Rectangle Fill="#3302133A" Margin="5,5,-5,-5">
            <Rectangle.Effect>
                <BlurEffect Radius="50"/>
            </Rectangle.Effect>
        </Rectangle>
        <Border BorderThickness="1,1,1,1" BorderBrush="#FFC9C9C9" Background="#FFE4E8F1" d:LayoutOverrides="Height">
            <Grid x:Name="LayoutGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="26"/>
                    <RowDefinition/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>
                <Rectangle StrokeThickness="0" PreviewMouseLeftButtonDown="BtnWin_drag_PreviewMouseLeftButtonDown" >
                    <Rectangle.Fill>
                        <LinearGradientBrush EndPoint="1.001,0.5" StartPoint="0.015,0.5">
                            <GradientStop Color="Black"/>
                            <GradientStop Color="#FF5252AB" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Grid x:Name="WinTOP">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="109"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnWin_close" Grid.Column="1" Height="21" Margin="0,0,6.5,0" Style="{StaticResource CloseWinBtnStyle}" HorizontalAlignment="Right" Width="28" Click="BtnWin_close_Click" BorderThickness="1,1,1,2" Grid.ColumnSpan="2" Visibility="Hidden">
                        <Path Data="M8.2080002,0 L11.875,0 11.875,8.2080001 20.083,8.2080001 20.083,11.875 11.875,11.875 11.875,20.083 8.2080002,20.083 8.2080002,11.875 0,11.875 0,8.2080001 8.2080002,8.2080001 z" Fill="#FF2B2B2B" HorizontalAlignment="Center" RenderTransformOrigin="0.499999995441284,0.500000004558718" Stretch="Fill" StrokeThickness="0" Width="13" Height="13" VerticalAlignment="Center" Margin="0" >
                            <Path.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform/>
                                    <RotateTransform Angle="-135"/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </Path.RenderTransform>
                        </Path>
                    </Button>
                </Grid>
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" Margin="7,0,0,0" Width="147.667">
                    <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" FontFamily="Malgun Gothic" IsEnabled="False" Text="해상도 설정" VerticalAlignment="Center" Padding="0,0,0,3" Margin="0,0,0,1" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="12,7,12,7">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                        <Label Content="디스플레이 타입 :" Foreground="#FF131933" VerticalContentAlignment="Center"/>
                        <ComboBox x:Name="DisplayTypeCombo" ItemsSource="{Binding Source={tt:EnumBindingSource {x:Type local:DeviceOrientation}}}" SelectedIndex="0" Width="62" Height="24" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="12,0,0,0">
                        <Label Content="디스플레이 구성 :" Foreground="#FF131933" VerticalContentAlignment="Center"/>
                        <ComboBox x:Name="RowCombo" Width="46" Height="24" />
                        <Label Content="x" VerticalContentAlignment="Center" Foreground="#FF131933"/>
                        <ComboBox x:Name="ColumnCombo" Width="46" Height="24" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Height="36" Orientation="Horizontal" Margin="17,0,0,0">
                        <Label Content="가로 해상도 :" Foreground="#FF131933" VerticalContentAlignment="Center"/>
                        <TextBox x:Name="HeightPixTBox" Width="62" HorizontalContentAlignment="Center" MaxLines="1" BorderThickness="0" Height="22" d:LayoutOverrides="Width" Margin="7,0,7,0" />
                        <Label Content="픽셀" Foreground="#FF131933" VerticalContentAlignment="Center" Margin="-7,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Height="36" Orientation="Horizontal" Margin="17,0,0,0">
                        <Label Content="세로 해상도 :" Foreground="#FF131933" VerticalContentAlignment="Center"/>
                        <TextBox x:Name="WidthPixTBox" Width="62" HorizontalContentAlignment="Center" Margin="7" MaxLines="1" BorderThickness="0" />
                        <Label Content="픽셀" Foreground="#FF131933" VerticalContentAlignment="Center" Margin="-7,0,0,0"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="0,7,12,7" >
                    <Button x:Name="LBtn" Style="{DynamicResource ButtonStyle2}" MinWidth="88" >
                        <TextBlock x:Name="LBtn_Text" TextWrapping="Wrap" Text="저 장" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="13.333" FontWeight="Bold"/>
                    </Button>
                    <Button x:Name="RBtn" Style="{DynamicResource Btn_defaultSW}" Margin="8,0,0,0" MinWidth="88" >
                        <TextBlock x:Name="RBtn_Text" TextWrapping="Wrap" Text="취 소" Foreground="#FF565656" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Malgun Gothic" FontSize="13.333" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>