<Window x:Class="AndoW_Manager.SubWindow.EditSpecialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AndoW_Manager.SubWindow"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="스케줄 수정" Closing="Window_Closing" Loaded="Window_Loaded"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" Width="438" Height="734">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="ButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="MouseOver">
                                            <Storyboard>
                                                <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)" Storyboard.TargetName="border">
                                                    <EasingColorKeyFrame KeyTime="0" Value="#FF2A446B" />
                                                </ColorAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)" Storyboard.TargetName="border">
                                                    <EasingColorKeyFrame KeyTime="0" Value="#FF122540" />
                                                </ColorAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)" Storyboard.TargetName="border">
                                                    <EasingColorKeyFrame KeyTime="0" Value="#FF404040" />
                                                </ColorAnimationUsingKeyFrames>
                                                <ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)" Storyboard.TargetName="contentPresenter">
                                                    <EasingColorKeyFrame KeyTime="0" Value="#FF7A7A7A" />
                                                </ColorAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Border x:Name="border" BorderThickness="1" CornerRadius="3" Background="#FF4B41C5" BorderBrush="#FF32299E">
                                    <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BtnWin_1" TargetType="{x:Type Button}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualStateGroup.Transitions>
                                            <VisualTransition GeneratedDuration="0" To="MouseOver">
                                                <VisualTransition.GeneratedEasingFunction>
                                                    <BackEase EasingMode="EaseOut" />
                                                </VisualTransition.GeneratedEasingFunction>
                                            </VisualTransition>
                                        </VisualStateGroup.Transitions>
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="MouseOver">
                                            <Storyboard>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="rectangle">
                                                    <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1" />
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed" />
                                        <VisualState x:Name="Disabled" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Rectangle x:Name="rectangle" Fill="#59000000" RadiusY="3" RadiusX="3" Stroke="#660F313F" Opacity="0" />
                                <ContentPresenter OpacityMask="Black" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True" />
                                <Trigger Property="IsDefaulted" Value="True" />
                                <Trigger Property="IsMouseOver" Value="True" />
                                <Trigger Property="IsPressed" Value="True" />
                                <Trigger Property="IsEnabled" Value="False" />
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Rectangle Fill="#3302133A" Margin="10,10,-5,-5">
            <Rectangle.Effect>
                <BlurEffect Radius="50" />
            </Rectangle.Effect>
        </Rectangle>
        <Border Background="#FFE4E8F1" BorderBrush="#FF4A4A9A" BorderThickness="1,1,1,1">
            <Grid>
                <GroupBox Margin="0,6,0,0"
                          Style="{DynamicResource MaterialDesignCardGroupBox}"
                          materialDesign:ThemeAssist.Theme="Light"
                          Background="White">
                    <GroupBox.HeaderTemplate>
                        <DataTemplate>
                        </DataTemplate>
                    </GroupBox.HeaderTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="67" />
                        </Grid.RowDefinitions>
                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Background="#F5F5F5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="GroupRadio" BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}" Style="{StaticResource MaterialDesignTabRadioButtonTop}" Checked="TargetToggle_Changed" Unchecked="TargetToggle_Changed" IsChecked="False" Content="그룹 선택" />
                                <RadioButton x:Name="SingleRadio" Grid.Column="1" BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}" Style="{StaticResource MaterialDesignTabRadioButtonTop}" Checked="TargetToggle_Changed" Unchecked="TargetToggle_Changed" IsChecked="True" Content="개별 선택" />
                            </Grid>

                            <GroupBox x:Name="TargetSelectBox" Grid.Row="1" Header="그룹 선택" MinHeight="200" VerticalContentAlignment="Stretch" Foreground="Black" Background="#FFEBEDF1">
                                <GroupBox.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="White"/>
                                    </DataTemplate>
                                </GroupBox.HeaderTemplate>
                                <Grid>
                                    <Grid x:Name="GroupSelectBox" MinWidth="150">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="12,0,12,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16" VerticalAlignment="Center" Foreground="#7A7A7A"/>
                                            <TextBox Grid.Column="1" x:Name="GroupFilterTextBox" TextChanged="GroupFilterTextBox_TextChanged" Margin="0" Padding="2,5"  materialDesign:HintAssist.Hint="검색" materialDesign:TextFieldAssist.HasClearButton="True"/>
                                        </Grid>
                                        <CheckBox Grid.Row="1" x:Name="SelectAllChBox" Checked="SelectAllChBox_Checked" Unchecked="SelectAllChBox_Unchecked" IsThreeState="True" Content="전체 선택" HorizontalAlignment="Right" Margin="0,0,12,8"/>
                                        <ListBox Grid.Row="2" x:Name="TargetListBox" SelectionChanged="TargetListBox_SelectionChanged" Style="{StaticResource MaterialDesignFilterChipPrimaryListBox}" />
                                    </Grid>
                                    <Grid x:Name="PlayerSelectBox" MinWidth="150" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="12,0,12,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16" VerticalAlignment="Center" Foreground="#7A7A7A"/>
                                            <TextBox Grid.Column="1" x:Name="PlayerFilterTextBox" TextChanged="GroupFilterTextBox_TextChanged" Margin="0" Padding="2,5"  materialDesign:HintAssist.Hint="검색" materialDesign:TextFieldAssist.HasClearButton="True"/>
                                        </Grid>
                                        <CheckBox Grid.Row="1" x:Name="SelectAllPlayerChBox" Checked="SelectAllPlayerChBox_Checked" Unchecked="SelectAllPlayerChBox_Unchecked" IsThreeState="True" Content="전체 선택" HorizontalAlignment="Right" Margin="0,0,12,8"/>
                                        <ListBox Grid.Row="2" x:Name="TargetPlayerListBox" SelectionChanged="TargetPlayerListBox_SelectionChanged" Style="{StaticResource MaterialDesignFilterChipPrimaryListBox}" />
                                    </Grid>
                                </Grid>
                            </GroupBox>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16" >
                                <materialDesign:PackIcon Kind="PlaylistPlay" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="0,3,7,0" />
                                <ComboBox x:Name="SelectPlaylistCombo" Width="220" Style="{StaticResource MaterialDesignComboBox}" MinWidth="0" MinHeight="0" SelectionChanged="SelectPlaylistCombo_SelectionChanged" materialDesign:HintAssist.Hint="플레이 리스트 선택" materialDesign:HintAssist.HintOpacity=".26" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" x:Name="SpecialStack" HorizontalAlignment="Center" Visibility="Visible">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <DatePicker x:Name="StartDatePicker" CalendarOpened="StartDate_CalendarOpened" SelectedDateChanged="StartDatePicker_SelectedDateChanged" Width="114" materialDesign:HintAssist.Hint="시작 날짜" Style="{StaticResource MaterialDesignFloatingHintDatePicker}" MinWidth="0" MinHeight="0" />
                                    <DatePicker x:Name="EndDatePicker" CalendarOpened="EndDate_CalendarOpened" SelectedDateChanged="EndDatePicker_SelectedDateChanged" Width="114" materialDesign:HintAssist.Hint="종료 날짜" Style="{StaticResource MaterialDesignFloatingHintDatePicker}" MinWidth="0" MinHeight="0" Margin="12,0,0,0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" >
                                    <materialDesign:TimePicker x:Name="StartTimePicker" Is24Hours="True" SelectedTimeChanged="StartTimePicker_SelectedTimeChanged" Width="114" materialDesign:HintAssist.Hint="시작 시간" Style="{StaticResource MaterialDesignFloatingHintTimePicker}" MinWidth="0" MinHeight="0" />
                                    <materialDesign:TimePicker x:Name="EndTimePicker" Is24Hours="True" SelectedTimeChanged="EndTimePicker_SelectedTimeChanged" Width="114" materialDesign:HintAssist.Hint="종료 시간" Style="{StaticResource MaterialDesignFloatingHintTimePicker}" MinWidth="0" MinHeight="0" Margin="12,0,0,0" />
                                </StackPanel>
                                <StackPanel x:Name="DayToggleStack" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16">
                                    <ToggleButton x:Name="MonToggle" Content="월" FontSize="12" Width="24" Height="24" Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}" IsChecked="True" />
                                    <ToggleButton x:Name="TueToggle" Content="화" FontSize="12" Width="24" Height="24" Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}" IsChecked="True" Margin="12,0,0,0"/>
                                    <ToggleButton x:Name="WedToggle" Content="수" FontSize="12" Width="24" Height="24" Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}" IsChecked="True" Margin="12,0,0,0"/>
                                    <ToggleButton x:Name="ThuToggle" Content="목" FontSize="12" Width="24" Height="24" Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}" IsChecked="True" Margin="12,0,0,0"/>
                                    <ToggleButton x:Name="FriToggle" Content="금" FontSize="12" Width="24" Height="24" Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}" IsChecked="True" Margin="12,0,0,0"/>
                                    <ToggleButton x:Name="SatToggle" Content="토" FontSize="12" Width="24" Height="24" Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}" IsChecked="True" Margin="12,0,0,0"/>
                                    <ToggleButton x:Name="SunToggle" Content="일" FontSize="12" Width="24" Height="24" Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}" IsChecked="True" Margin="12,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <Button x:Name="EditSchduleBtn" Grid.Row="1" Click="EditSchduleBtn_Click" Height="50" Style="{StaticResource MaterialDesignRaisedLightButton}" MinWidth="0" MinHeight="0" Margin="24,0">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Width="20" Height="20" Kind="CalendarPlus" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                    <Label Content="스케줄 수정" VerticalContentAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </Grid>
                </GroupBox>
                <Grid x:Name="WinTOP" Grid.Row="0" Height="35" VerticalAlignment="Top">
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="1.0,0.5" StartPoint="0.0,0.5">
                            <GradientStop Color="Black" Offset="0" />
                            <GradientStop Color="#FF5252AB" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="스케줄 수정"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Foreground="White"
                        FontFamily="Malgun Gothic"
                        FontSize="13.333"
                        FontWeight="Bold" />

                    <Button x:Name="BtnWin_close"
                        Grid.Column="1"
                        Width="26"
                        Height="20"
                        Margin="0,0,6,0"
                        HorizontalAlignment="Right"
                        Style="{DynamicResource BtnWin_1}"
                        Click="BtnWin_close_Click"
                        BorderThickness="1,1,1,2">
                        <Path Data="M9.719,9.719C9.349,10.09,8.747,10.088,8.374,9.716L4.998,6.34 1.622,9.716C1.25,10.088,0.647,10.09,0.277,9.719 -0.094,9.349,-0.092,8.747,0.28,8.374L3.656,4.998 0.28,1.622C-0.092,1.249,-0.094,0.647,0.277,0.277 0.647,-0.094,1.25,-0.092,1.622,0.28L4.998,3.656 8.374,0.28C8.747,-0.092,9.349,-0.094,9.719,0.277 10.09,0.647,10.089,1.249,9.716,1.622L6.34,4.998 9.716,8.374C10.089,8.747,10.09,9.349,9.719,9.719z"
                            Fill="White"
                            Height="10"
                            Width="10"
                            Stretch="Fill"
                            Stroke="Black"
                            StrokeThickness="0"
                            UseLayoutRounding="False"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center" />
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
