									<RotateTransform Angle="-135"/>
									<TranslateTransform/>
								</TransformGroup>
							</Path.RenderTransform>
						</Path>
					</Button>
				</Grid>
				<StackPanel Orientation="Horizontal" Margin="7,0,0,0">
