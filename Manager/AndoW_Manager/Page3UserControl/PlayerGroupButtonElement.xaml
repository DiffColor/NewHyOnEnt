<UserControl x:Class="AndoW_Manager.PlayerGroupButtonElement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             PreviewMouseDoubleClick="UserControl_PreviewMouseDoubleClick"
             mc:Ignorable="d" Margin="2" >
    <UserControl.Resources>
        <ContextMenu x:Key="GroupContextMenu">
            <MenuItem x:Name="GroupEditMenuItem" Header="그룹 편집"  Click="GroupEditMenuItem_Click"/>
            <MenuItem x:Name="GroupDeleteMenuItem" Header="그룹 삭제" Click="GroupDeleteMenuItem_Click"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid ContextMenu="{StaticResource GroupContextMenu}" Margin="3,0,3,0">
        <Rectangle Fill="Black" Margin="5,5,-2,-2" Opacity="0.1">
            <Rectangle.Effect>
                <BlurEffect Radius="10"/>
            </Rectangle.Effect>
        </Rectangle>

        <Border x:Name="MainBorder" BorderThickness="1" CornerRadius="4,4,4,4" Background="White"/>
        <Border x:Name="SelectBorder" BorderThickness="2,2,2,2" BorderBrush="#FF4176DE" CornerRadius="4,4,4,4" Visibility="Hidden" />


        <Grid x:Name="GroupBackground" Margin="1" Background="#00000000">
            <Grid.RowDefinitions>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Vertical" d:LayoutOverrides="Width, Height" Margin="5,3,5,3">

                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                    HorizontalScrollBarVisibility="Disabled" d:LayoutOverrides="LeftPosition, RightPosition, TopPosition, BottomPosition" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Background="#00000000">
                        <Image x:Name="GroupLogoImage" Stretch="Uniform" Margin="0,0,0,8" Visibility="Collapsed" MaxHeight="40" />
                        <TextBlock x:Name="GroupNameText" Text="그룹 이름" Foreground="#FF081A2F" FontWeight="Bold" HorizontalAlignment="Stretch" TextWrapping="Wrap" TextAlignment="Center" Margin="2"/>
                    </StackPanel>
                </ScrollViewer>
                <Rectangle Height="0.5" Stroke="#33000000" Margin="0,0,0,2"/>
                <TextBlock x:Name="GroupPlayerCountText" Text="0대" Foreground="#FF081C2F" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>

            </StackPanel>
        </Grid>

        <!-- 선택 표시 화살표 -->
    </Grid>
</UserControl>
