<UserControl x:Class="AndoW_Manager.WeekSchInfoElement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="300" Height="30">
	<UserControl.Resources>
        <Style x:Key="ButtonFocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="2" SnapsToDevicePixels="true" Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" StrokeThickness="1" StrokeDashArray="1 2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <LinearGradientBrush x:Key="ButtonNormalBackground" EndPoint="0,1" StartPoint="0,0">
			<GradientStop Color="#F3F3F3" Offset="0"/>
			<GradientStop Color="#EBEBEB" Offset="0.5"/>
			<GradientStop Color="#DDDDDD" Offset="0.5"/>
			<GradientStop Color="#CDCDCD" Offset="1"/>
		</LinearGradientBrush>
		<SolidColorBrush x:Key="ButtonNormalBorder" Color="#FF707070"/>
		<Style x:Key="Btn_default4" TargetType="{x:Type Button}">
			<Setter Property="FocusVisualStyle" Value="{StaticResource ButtonFocusVisual}"/>
			<Setter Property="Background" Value="{StaticResource ButtonNormalBackground}"/>
			<Setter Property="BorderBrush" Value="{StaticResource ButtonNormalBorder}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Padding" Value="1"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="{x:Type Button}">
						<Grid>
							<VisualStateManager.VisualStateGroups>
								<VisualStateGroup x:Name="CommonStates">
									<VisualStateGroup.Transitions>
										<VisualTransition GeneratedDuration="0:0:0.05" To="MouseOver">
											<Storyboard/>
										</VisualTransition>
										<VisualTransition From="MouseOver" GeneratedDuration="0:0:0.05"/>
									</VisualStateGroup.Transitions>
									<VisualState x:Name="Normal"/>
									<VisualState x:Name="MouseOver">
										<Storyboard>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[5].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="#FF494949"/>
											</ColorAnimationUsingKeyFrames>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[4].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="#FF646464"/>
											</ColorAnimationUsingKeyFrames>
										</Storyboard>
									</VisualState>
									<VisualState x:Name="Pressed">
										<Storyboard>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[5].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="#FF1A1A1A"/>
											</ColorAnimationUsingKeyFrames>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[0].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="#FF1B1B1B"/>
											</ColorAnimationUsingKeyFrames>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[4].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="#FF161616"/>
											</ColorAnimationUsingKeyFrames>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[2].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="#FF232323"/>
											</ColorAnimationUsingKeyFrames>
											<ColorAnimationUsingKeyFrames Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[1].(GradientStop.Color)" Storyboard.TargetName="rectangle">
												<EasingColorKeyFrame KeyTime="0" Value="Black"/>
											</ColorAnimationUsingKeyFrames>
										</Storyboard>
									</VisualState>
									<VisualState x:Name="Disabled"/>
								</VisualStateGroup>
							</VisualStateManager.VisualStateGroups>
							<Rectangle x:Name="rectangle" RadiusY="2" RadiusX="2" Stroke="#62000000">
								<Rectangle.Fill>
									<LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
										<GradientStop Color="#FF5E5E5E" Offset="0.031"/>
										<GradientStop Color="#FF6C6C6C"/>
										<GradientStop Color="#FF393939" Offset="0.898"/>
										<GradientStop Color="#FF1A1A1A" Offset="0.988"/>
										<GradientStop Color="#FF333333" Offset="0.105"/>
										<GradientStop Color="#FF2B2B2B" Offset="0.449"/>
									</LinearGradientBrush>
								</Rectangle.Fill>
							</Rectangle>
							<ContentPresenter HorizontalAlignment="Center" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center" OpacityMask="Black"/>
						</Grid>
						<ControlTemplate.Triggers>
							<Trigger Property="IsKeyboardFocused" Value="true"/>
							<Trigger Property="ToggleButton.IsChecked" Value="true"/>
							<Trigger Property="IsEnabled" Value="false">
								<Setter Property="Foreground" Value="#ADADAD"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>
	<Grid x:Name="rootGrid">
		<Grid x:Name="LayoutGrid">
			<Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="80"/>
			</Grid.ColumnDefinitions>
			<Rectangle x:Name="BackRectangle" Grid.ColumnSpan="2"/>
			<TextBlock x:Name="DisplaytimeText_Copy" HorizontalAlignment="Left" TextWrapping="Wrap" FontFamily="Malgun Gothic" IsEnabled="False" Text="방송안함" VerticalAlignment="Center" Padding="0" Foreground="Black" FontSize="10.667" Margin="3,8.562,0,8.562" Height="12.876" Width="42.667"/>
            <StackPanel x:Name="WeekStackPanel1" Grid.Column="1" Orientation="Horizontal" d:IsHidden="True">
				<ComboBox x:Name="DispStartHourCombo" VerticalAlignment="Center" Height="22" Width="48" HorizontalAlignment="Left" Margin="2,0,0,0"/>
				<ComboBox x:Name="DispStartMinCombo" VerticalAlignment="Center" Height="22" Width="48" HorizontalAlignment="Left" Margin="2,0,0,0"/>
				<TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" FontFamily="Malgun Gothic" FontSize="13.333" IsEnabled="False" Text="~" VerticalAlignment="Center" Padding="0,0,0,3" Foreground="#FFA6A6A6" Height="20.704" Margin="2,0,0,0">
					<TextBlock.Effect>
						<DropShadowEffect BlurRadius="0" ShadowDepth="1" Opacity="0.1" Color="#FF004A58"/>
					</TextBlock.Effect></TextBlock>
				<ComboBox x:Name="DispEndHourCombo" VerticalAlignment="Center" Height="22" Width="48" HorizontalAlignment="Left"/>
				<ComboBox x:Name="DispEndMinCombo" VerticalAlignment="Center" Height="22" Width="48" HorizontalAlignment="Left" Margin="2,0,0,0"/>
			</StackPanel>
			<TextBlock x:Name="DisplaytimeText" Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" FontFamily="Malgun Gothic" FontSize="13.333" IsEnabled="False" Text="09:00 ~ 19:00" VerticalAlignment="Center" Foreground="Black" Margin="2" />
			<Button x:Name="BorderBTN_Copy1" Content="시간 수정" FontFamily="Malgun Gothic" Style="{DynamicResource Btn_defaultSW}" Foreground="#FF23369C" FontSize="10.667" Grid.Column="2" Margin="3,5,0,5"/>
		</Grid>
	</Grid>
</UserControl>
