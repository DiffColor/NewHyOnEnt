<Window x:Class="TurtleTools.DbLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DB 구동중"
        Height="180"
        Width="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#FF1E1E1E"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#FF2C2C2C" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#FF3D3D3D">
        <StackPanel>
            <TextBlock Text="DB 구동중..." FontSize="18" FontWeight="Bold" Foreground="#FFFAFAFA" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="준비가 완료될 때까지 잠시 기다려 주세요." FontSize="13" Foreground="#FFCFCFCF" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
            <ProgressBar IsIndeterminate="True" Height="14" Margin="0,18,0,0"/>
        </StackPanel>
    </Border>
</Window>
