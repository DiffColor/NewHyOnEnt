<UserControl 
    x:Class="PageViewer.MediaControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:PageViewer"
    mc:Ignorable="d" >
    <Grid x:Name="ContentGrid">
        <MediaElement x:Name="MEDisplayElement" LoadedBehavior="Manual" Stretch="Uniform" OpacityMask="Black" Visibility="Hidden">
            <MediaElement.RenderTransform>
                <RotateTransform x:Name="MEDisplayElementTransform" Angle="0" />
            </MediaElement.RenderTransform>
        </MediaElement>
        <Image x:Name="ImageCtrl" Stretch="Uniform" Visibility="Hidden" />
    </Grid>
</UserControl>
